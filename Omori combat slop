            user.set_emotion(self.battle_start_emotion, duration=999)
            animated_print(f"<DELAY:0.5>  {Colors.CYAN}[Gear]{Colors.RESET} {user.name}'s {self.name} makes them {self.battle_start_emotion.capitalize()}!")

