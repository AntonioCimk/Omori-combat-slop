        if battle:
            if getattr(battle, 'last_hit_crit', False): 
                s += f"<DELAY:0.3> {Colors.YELLOW}CRITICAL HIT!{Colors.RESET}"
            if getattr(battle, 'last_hit_weakness', False): 
                s += f"<DELAY:0.3> {Colors.PINK}Weakness!{Colors.RESET}"
