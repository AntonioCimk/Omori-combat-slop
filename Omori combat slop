def get_equipment_desc(eq):
    parts =[]
    if eq.atk_bonus: parts.append(f"ATK +{eq.atk_bonus}")
    if eq.dfn_bonus: parts.append(f"DFN +{eq.dfn_bonus}")
    if eq.spd_bonus: parts.append(f"SPD +{eq.spd_bonus}")
    if eq.max_hp_bonus: parts.append(f"HP +{eq.max_hp_bonus}")
    if eq.max_mp_bonus: parts.append(f"MP +{eq.max_mp_bonus}")
    if eq.battle_start_emotion: parts.append(f"Starts {eq.battle_start_emotion.capitalize()}")
    if eq.passive_name: parts.append(f"Passive: {eq.passive_name}")
    
    eff_kind = eq.effect.get("kind")
    if eff_kind == "immunity": parts.append(f"Immunity +{eq.effect.get('charges')}")
    elif eff_kind == "status": parts.append(f"Grants {eq.effect.get('status')}")
    
    return ", ".join(parts) if parts else "No special effects."
    
# ENCOUNTER GENERATION & TESTING

def create_random_encounter(party, average_level):
    global RANDOM_BOSS_DEFEATED
    boss_thresholds =[
        (24, "gilded_sun"), (26, "widow_of_ash"), (28, "ember_warlord"),
        (29, "triad_mirrors"), (30, "veiled_oracle"), (31, "thorned_parliament"),
        (31, "choir_hollow_sun"), (33, "maw_tribunal")
    ]
    for boss_lvl, boss_id in boss_thresholds:
        if average_level >= boss_lvl and boss_id not in RANDOM_BOSSES_DEFEATED:
            RANDOM_BOSSES_DEFEATED.add(boss_id)
            clear_screen()
            print(f"\n{Colors.RED}{Colors.BOLD} ⚠ WARNING: A POWERFUL PRESENCE APPROACHES! ⚠ {Colors.RESET}\n")
            time.sleep(2.5)
            return create_group_boss_encounter(party, boss_id, boss_lvl)

    foe_classes =[
        JoyWisp, EmberBrute, MourningClerk, JubilantHarlequin, RageKnight,
        GloomMatron, PanicHowlerA, PanicHowlerB, DrillSergeant, BrassMedic, VeilLeech,
        SmileCaster, EmberSinger, MournNurse, TheClown
    ]
    num_foes = random.randint(1, 4)
    enemies =[]
    for _ in range(num_foes):
        foe_level = max(1, average_level - random.randint(0, 2))
        enemies.append(random.choice(foe_classes)(foe_level))

    name_counts, current_counts = {}, {}
    for e in enemies: name_counts[e.name] = name_counts.get(e.name, 0) + 1
    for e in enemies:
        if name_counts[e.name] > 1:
            current_counts[e.name] = current_counts.get(e.name, 0) + 1
            e.name = f"{e.name} {chr(64 + current_counts[e.name])}"

    return Battle(party, enemies, battle_type="Random Encounter")

def create_group_boss_encounter(party, boss_type, average_level):
    lvl = max(1, average_level)
    diff_mult = {"Easy": 0.85, "Normal": 1.0, "Hard": 1.2, "Brutal": 1.4}.get(DIFFICULTY, 1.0)
    
    if boss_type == "gilded_sun": enemies = [GildedSun(24)]
    elif boss_type == "widow_of_ash": enemies = [WidowOfAsh(26)]
    elif boss_type == "ember_warlord": enemies = [EmberWarlord(28)]
    elif boss_type == "veiled_oracle": enemies = [VeiledOracle(30)]
    elif boss_type == "choir_hollow_sun": enemies = [MasterChoirShell(31)]
    elif boss_type == "maw_tribunal": enemies = [MawOfTheTribunal(33)]
    elif boss_type == "triad_mirrors": enemies =[PrismMirror(29), FractureMirror(30), ShardMirror(31)]
    elif boss_type == "thorned_parliament": enemies =[BrambleSpeaker(30), RootSpeaker(31), CrownThorn(32)]
    elif boss_type == "triumvirate":
        sun = GildedSun(lvl)
        sun.max_hp = sun.hp = int(15000 * diff_mult); sun.base_atk = int(80 * diff_mult); sun.base_spd = int(90 * diff_mult); sun.base_dfn = int(70 * diff_mult)
        
        widow = WidowOfAsh(lvl)
        widow.max_hp = widow.hp = int(15000 * diff_mult); widow.base_atk = int(70 * diff_mult); widow.base_spd = int(80 * diff_mult); widow.base_dfn = int(110 * diff_mult)
        
        war = EmberWarlord(lvl)
        war.max_hp = war.hp = int(15000 * diff_mult); war.base_atk = int(85 * diff_mult); war.base_spd = int(75 * diff_mult); war.base_dfn = int(70 * diff_mult)
        
        enemies = [sun, widow, war]

    pretty_name = boss_type.replace('_', ' ').title()
    return Battle(party, enemies, battle_type=f"Boss: {pretty_name}")

