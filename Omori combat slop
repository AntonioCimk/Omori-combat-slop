def open_shop():
    global PARTY_COINS
    grouped_items = {}
    for item in ITEMS.values():
        grouped_items.setdefault(item.category.capitalize(),[]).append(item)

    shop_inventory = {}
    for cat, items_in_cat in grouped_items.items():
        shop_inventory[cat] = random.sample(items_in_cat, min(4, len(items_in_cat)))

    shop_equips = random.sample(list(EQUIPMENT.values()), min(4, len(EQUIPMENT)))

    while True:
        clear_screen()
        print("\n" + Colors.MAGENTA + "="*50 + Colors.RESET)
        print(f" {Colors.YELLOW}🛒 WELCOME TO THE SHOP!{Colors.RESET} | Wallet: {Colors.YELLOW}{PARTY_COINS} Coins{Colors.RESET}")
        print(Colors.MAGENTA + "="*50 + Colors.RESET)
        cats = list(shop_inventory.keys())
        for i, cat in enumerate(cats):
            print(f"[{Colors.CYAN}{i+1}{Colors.RESET}] {cat} Items")
        print(f"[{Colors.CYAN}{len(cats)+1}{Colors.RESET}] Equipment")
