# CORE CHARACTER PATCH

MAX_SKILLS_PER_CHARACTER = 6

class Character:
    def __init__(self, name, hp, mana, atk, dfn, spd):
        self.name = name

        self.max_hp = hp
        self.hp = hp

        self.max_mana = mana
        self.mana = mana

        self.base_atk = atk
        self.base_dfn = dfn
        self.base_spd = spd

        self.base_crit_chance = 0.05
        self.base_crit_power = 0.50

        self.emotion = "neutral"
        self.emotion_duration = 0
        self.max_emotion_level = 2

        self.on_hit_callback = None
        self.is_alive = True
        self.is_defending = False

        self.status_effects = {}
        self.immunity_charges = 0
        self.item_cooldowns = {}
        self.energy = 0
        self.status_stacks = {} 

        # temporary battle effects like Stare, Guard, Freeze slow, etc.
        self.temp_values = {}
        self.temp_effects = {}
        self.pending_freeze_slow = False
        self.skills = {}
        self.equipment = None
        self.battle_start_emotion_applied = False
        self.battle_announcements = []
        
    def get_hit_rate(self):
        hit_chance = 1.0 
        hit_chance += Emotions.get_hit_modifier(self.emotion)
        
        if "Focus+" in self.status_effects: hit_chance += 0.10
        elif "Focus++" in self.status_effects: hit_chance += 0.20
        elif "Focus+++" in self.status_effects: hit_chance += 0.30
        
        if "Distracted" in self.status_effects: hit_chance -= 0.10
        elif "Distracted--" in self.status_effects: hit_chance -= 0.20
        elif "Distracted---" in self.status_effects: hit_chance -= 0.30
        
        if "Blind" in self.status_effects: hit_chance -= 0.50
        if "Dizzy" in self.status_effects: hit_chance -= 0.30
        
        return hit_chance
    
    def has_passive(self, passive_name):
        """Checks both the character's innate passive and their equipment passive!"""
        if getattr(self, "passive_name", "") == passive_name: return True
        if self.equipment and self.equipment.passive_name == passive_name: return True
        return False

    def equip_equipment(self, equipment):
        if self.equipment is not None:
            self.unequip_equipment()
        self.equipment = equipment
        self.max_hp += equipment.max_hp_bonus
        self.max_mana += equipment.max_mp_bonus
        self.hp = min(self.hp, self.max_hp)
        self.mana = min(self.mana, self.max_mana)
        return f"{self.name} equipped {equipment.name}."

    def unequip_equipment(self):
        if self.equipment is not None:
            self.max_hp -= self.equipment.max_hp_bonus
            self.max_mana -= self.equipment.max_mp_bonus
            self.hp = min(self.hp, self.max_hp)
            self.mana = min(self.mana, self.max_mana)
            name = self.equipment.name
            self.equipment = None
            return f"{self.name} unequipped {name}."
        return ""

    def get_effective_stat(self, stat_name):
        base_val = getattr(self, f"base_{stat_name}")
        
        
        if self.equipment:
            base_val += getattr(self.equipment, f"{stat_name}_bonus", 0)
            
        modifier = 1.0

        if stat_name == "atk":
            if "Attack+" in self.status_effects: modifier += 0.15
            if "Attack++" in self.status_effects: modifier += 0.30
            if "Attack-" in self.status_effects: modifier -= 0.15
            if "Attack--" in self.status_effects: modifier -= 0.30
            if "Friendship" in self.status_effects: modifier += 0.10
            modifier *= self.temp_values.get("atk_mult", 1.0)
            modifier = max(0.2, min(2.0, modifier))

        elif stat_name == "dfn":
            if "Defense+" in self.status_effects: modifier += 0.15
            if "Defense++" in self.status_effects: modifier += 0.30
            if "Defense-" in self.status_effects: modifier -= 0.15
            if "Defense--" in self.status_effects: modifier -= 0.30
            if "Friendship" in self.status_effects: modifier += 0.10
            modifier *= self.temp_values.get("dfn_mult", 1.0)
            modifier = max(0.2, min(2.0, modifier))

        elif stat_name == "spd":
            if "Speed+" in self.status_effects: modifier += 0.10
            if "Speed++" in self.status_effects: modifier += 0.20
            if "Speed-" in self.status_effects: modifier -= 0.15
            if "Speed--" in self.status_effects: modifier -= 0.30
            if "Friendship" in self.status_effects: modifier += 0.08
            if getattr(self, "pending_freeze_slow", False):
                modifier -= 0.10
                self.pending_freeze_slow = False
            modifier *= self.temp_values.get("spd_mult", 1.0)
            modifier = max(0.5, min(1.8, modifier))

        return int(base_val * modifier * Emotions.get_stat_multiplier(self.emotion, stat_name))     
    def reset_state(self):
        """Wipes temporary battle data to prepare for the next fight."""
        self.status_effects.clear()
        self.status_stacks.clear()
        self.immunity_charges = 0
        self.item_cooldowns.clear()
        self.temp_values.clear()
        self.temp_effects.clear()
        self.pending_freeze_slow = False
        self.is_defending = False
        self.skip_turn = False
        self.basic_attack_only = False
        self.emotion = "neutral"
        self.emotion_duration = 0
        self.battle_start_emotion_applied = False
        self.energy = 0 
        if hasattr(self, 'has_followed_up'):
            self.has_followed_up = False
            
        if self.hp <= 0: # Prevents 0 HP soft-locks out of battle
            self.hp = 1
            self.is_downed = False
            self.is_alive = True
            
        self.hp = self.max_hp
        self.mana = self.max_mana
        self.is_downed = False
        self.is_alive = True
        
        self.battle_announcements.clear()

    def is_obscured(self):
        """Returns True if the character's stats/emotions should be hidden from the player."""
        return "Obscured" in self.status_effects or Emotions.get_root(self.emotion) == "obscured"

    def get_display_hp(self):
        """Use this for battle UI and health bars."""
        if self.is_obscured():
            return "???"
        return f"{self.hp}/{self.max_hp}"

    def get_display_mana(self):
        """Use this for battle UI and mana bars."""
        if self.is_obscured():
            return "???"
        return f"{self.mana}/{self.max_mana}"

    def get_display_emotion(self):
        """Use this for the UI emotion face/text."""
        if self.is_obscured():
            return "???"
        return self.emotion.capitalize()

    def get_status_readout(self):
        """A helper to print the character's current state to the screen."""
        if self.is_obscured():
            return f"{self.name} | HP: ??? | MP: ??? | Emotion: ??? | Energy: ???"
        return f"{self.name} | HP: {self.hp}/{self.max_hp} | MP: {self.mana}/{self.max_mana} | Emotion: {self.emotion.capitalize()} | Energy: {self.energy}"
    def equip_skill(self, skill):
        if skill.name in self.skills:
            return f"{skill.name} is already equipped."

        if len(self.skills) >= MAX_SKILLS_PER_CHARACTER:
            return f"{self.name} can only equip {MAX_SKILLS_PER_CHARACTER} skills."

        self.skills[skill.name] = skill
        return f"{self.name} equipped {skill.name}."

    def unequip_skill(self, skill_name):
        if skill_name in self.skills:
            del self.skills[skill_name]
            return f"{self.name} unequipped {skill_name}."
        return f"{skill_name} is not equipped."

    def equip_equipment(self, equipment):
        if self.equipment is not None:
            return f"{self.name} can only equip 1 piece of equipment."

        self.equipment = equipment
        return f"{self.name} equipped {equipment.name}."

    def apply_temp_effect(self, key, value, turns):
        self.temp_values[key] = value
        self.temp_effects[key] = turns

    def set_emotion(self, emotion, duration=0, force = False):
        if getattr(self, "temp_values", {}).get("emotion_lock"):
            if hasattr(self, "battle_announcements"):
                self.battle_announcements.append(f"\n<DELAY:0.5>  [!] {self.name}'s emotion is anchored and cannot be changed!")

        if self.max_emotion_level <= 0:
            self.emotion = "neutral"
            return
        if self.max_emotion_level <= 0 and not force:
            self.emotion = "neutral"
            return

        target_root = Emotions.get_root(emotion)
        current_root = Emotions.get_root(self.emotion)
        max_idx = 2 if force else max(0, self.max_emotion_level - 1)

        if target_root not in ["happy", "sad", "angry"]:
            self.emotion = target_root
            self.emotion_duration = duration
            return

        requested_tier = Emotions.get_tier(emotion)
        
        if force:
            new_tier = requested_tier
        elif requested_tier > 0:
           
            new_tier = min(requested_tier, max_idx)
        else:
            
            if target_root == current_root:
                current_tier = Emotions.get_tier(self.emotion)
                if current_tier >= max_idx:
                    return
                new_tier = current_tier + 1
            else:
                new_tier = 0

        new_tier = max(0, min(2, new_tier))

        if target_root == "happy":
            self.emotion = Emotions.HAPPY[new_tier]
        elif target_root == "sad":
            self.emotion = Emotions.SAD[new_tier]
        elif target_root == "angry":
            self.emotion = Emotions.ANGRY[new_tier]

        self.emotion_duration = duration

    def heal(self, amount):
        if self.hp <= 0:
            return 0
        before = self.hp
        self.hp = min(self.max_hp, self.hp + int(amount))
        return self.hp - before

    def receive_heal(self, amount, source=None):
        return self.heal(amount)

    def restore_mana(self, amount):
        before = self.mana
        self.mana = min(self.max_mana, self.mana + int(amount))
        return self.mana - before

    def gain_energy(self, amount):
        self.energy = min(100, self.energy + amount)

    def remove_one_debuff(self):
        for key in list(self.status_effects.keys()):
            if key in effects.Negative_effects:
                if key in self.status_stacks and self.status_stacks[key] > 1:
                    self.status_stacks[key] -= 1
                    return f"one stack of {key}"
                elif "---" in key:
                    del self.status_effects[key]; self.status_effects[key.replace("---", "--")] = 2
                    return f"one stage of {key.replace('---', ' penalty')}"
                elif "--" in key:
                    del self.status_effects[key]; self.status_effects[key.replace("--", "-")] = 2
                    return f"one stage of {key.replace('--', ' penalty')}"
                else:
                    del self.status_effects[key]
                    if key in self.status_stacks: del self.status_stacks[key]
                    return key
        return None

    def remove_all_debuffs(self):
        removed =[]
        for key in list(self.status_effects.keys()):
            if key in effects.Negative_effects:
                removed.append(key)
                del self.status_effects[key]
                if hasattr(self, 'status_stacks') and key in self.status_stacks:
                    del self.status_stacks[key]
        return removed

    def try_add_status(self, status_name, duration):
        status_name = effects.normalize(status_name)

        if status_name in effects.Negative_effects and self.immunity_charges > 0:
            self.immunity_charges -= 1
            return f"{self.name}'s immunity blocked {status_name}!"
            
        if self.temp_values.get("slipstream_active"):
            if "Speed" in status_name or "Focus" in status_name or "Distracted" in status_name:
                return f"Slipstream prevented stat changes!"

        chains = [
            (["Attack+", "Attack++", "Attack+++"], "Attack", True),
            (["Attack-", "Attack--", "Attack---"], "Attack", False),
            (["Defense+", "Defense++", "Defense+++"], "Defense", True),
            (["Defense-", "Defense--", "Defense---"], "Defense", False),
            (["Speed+", "Speed++", "Speed+++"], "Speed", True),
            (["Speed-", "Speed--", "Speed---"], "Speed", False),
            (["Focus+", "Focus++", "Focus+++"], "Focus", True),
            (["Distracted", "Distracted--", "Distracted---"], "Focus", False),
            (["Crit power+", "Crit power++", "Crit power+++"], "Crit Power", True),
            (["Exhausted", "Exhausted--", "Exhausted---"], "Crit Power", False),
        ]

        for chain, stat_name, is_buff in chains:
            if status_name in chain:
                # Enforce Omori's 6-turn standard duration for stat changes
                status_duration = 6 
                
                delta = chain.index(status_name) + 1 
                current_tier = 0
                current_status = None
                
                for i, s in enumerate(chain):
                    if s in self.status_effects:
                        current_tier = i + 1
                        current_status = s
                        break
                
                if current_tier == 3:
                    return f"{self.name}'s {stat_name} cannot go any {'higher' if is_buff else 'lower'}!"
                
                new_tier = min(3, current_tier + delta)
                new_status = chain[new_tier - 1]
                
                if current_status:
                    del self.status_effects[current_status]
                    
                self.status_effects[new_status] = status_duration
                
                is_sharp = (new_tier - current_tier) > 1
                return Narrator.stat_change(self.name, stat_name, is_buff, is_sharp)
                
                dir_word = "rose" if is_buff else "fell"
                magnitude = " sharply" if (new_tier - current_tier) > 1 else ""
                return f"{self.name}'s {stat_name} {dir_word}{magnitude}!"

        ## Stackables (Poison, Burn, etc.)
        stackable = ["Poisoned", "Burned", "Bleeding", "Confused", "Dizzy", "Sleepy"]
        if status_name in stackable:
            if status_name in self.status_effects:
                current_stacks = self.status_stacks.get(status_name, 1)
                if current_stacks < 3:
                    self.status_stacks[status_name] = current_stacks + 1
                    self.status_effects[status_name] = max(self.status_effects[status_name], duration)
                    base_flavor = Narrator.get_status_flavor(self.name, status_name)
                    return f"{base_flavor} (Worsened to x{current_stacks + 1}!)"
                else:
                    self.status_effects[status_name] = max(self.status_effects[status_name], duration)
                    return f"{self.name}'s {status_name} cannot get any worse!"
            else:
                self.status_effects[status_name] = duration
                self.status_stacks[status_name] = 1
                return Narrator.get_status_flavor(self.name, status_name)

        self.status_effects[status_name] = duration
        return Narrator.get_status_flavor(self.name, status_name)

    def get_effective_stat(self, stat_name):
        base_val = getattr(self, f"base_{stat_name}")
        if self.equipment:
            base_val += getattr(self.equipment, f"{stat_name}_bonus", 0)

        buff_mult = 1.0
        debuff_mult = 1.0

        if stat_name == "atk":
            if "Attack+" in self.status_effects: buff_mult = 1.10
            elif "Attack++" in self.status_effects: buff_mult = 1.25
            elif "Attack+++" in self.status_effects: buff_mult = 1.50
            
            if "Attack-" in self.status_effects: debuff_mult = 0.90
            elif "Attack--" in self.status_effects: debuff_mult = 0.80
            elif "Attack---" in self.status_effects: debuff_mult = 0.70

        elif stat_name == "dfn":
            if "Defense+" in self.status_effects: buff_mult = 1.15
            elif "Defense++" in self.status_effects: buff_mult = 1.30
            elif "Defense+++" in self.status_effects: buff_mult = 1.50
            
            if "Defense-" in self.status_effects: debuff_mult = 0.75
            elif "Defense--" in self.status_effects: debuff_mult = 0.50
            elif "Defense---" in self.status_effects: debuff_mult = 0.25

        elif stat_name == "spd":
            if "Speed+" in self.status_effects: buff_mult = 1.50
            elif "Speed++" in self.status_effects: buff_mult = 2.00
            elif "Speed+++" in self.status_effects: buff_mult = 3.00 
            
            if "Speed-" in self.status_effects: debuff_mult = 0.80
            elif "Speed--" in self.status_effects: debuff_mult = 0.50
            elif "Speed---" in self.status_effects: debuff_mult = 0.25

        special_mult = self.temp_values.get(f"{stat_name}_mult", 1.0)
        
        if "Release Energy" in self.status_effects: special_mult *= 1.25
        if "Basil Release Energy" in self.status_effects: special_mult *= 1.50 
            
        if stat_name == "atk" and "Friendship" in self.status_effects: special_mult *= 1.10
        if stat_name == "dfn" and "Friendship" in self.status_effects: special_mult *= 1.10
        if stat_name == "spd" and "Friendship" in self.status_effects: special_mult *= 1.08

        final_stat = base_val * Emotions.get_stat_multiplier(self.emotion, stat_name) * buff_mult * debuff_mult * special_mult
        
        if stat_name == "spd" and getattr(self, "pending_freeze_slow", False):
            final_stat *= 0.90
            self.pending_freeze_slow = False
            
        return min(999, max(1, int(round(final_stat))))

    def calculate_crit(self, base_crit_chance, base_crit_power):
        modifier_chance = 0.0
        modifier_power = 0.0

        if "Focus+" in self.status_effects: modifier_chance += 0.10
        elif "Focus++" in self.status_effects: modifier_chance += 0.20
        elif "Focus+++" in self.status_effects: modifier_chance += 0.30
        
        if "Distracted" in self.status_effects: modifier_chance -= 0.15
        elif "Distracted--" in self.status_effects: modifier_chance -= 0.30
        elif "Distracted---" in self.status_effects: modifier_chance -= 0.45

        if "Crit power+" in self.status_effects: modifier_power += 0.20
        elif "Crit power++" in self.status_effects: modifier_power += 0.40
        elif "Crit power+++" in self.status_effects: modifier_power += 0.60
        
        if "Exhausted" in self.status_effects: modifier_power -= 0.20
        elif "Exhausted--" in self.status_effects: modifier_power -= 0.40
        elif "Exhausted---" in self.status_effects: modifier_power -= 0.60

        modifier_chance += self.temp_values.get("crit_add", 0.0)
        modifier_power += self.temp_values.get("crit_power_add", 0.0)

        luck_mult = Emotions.DATA.get(Emotions.normalize(self.emotion), Emotions.DATA["neutral"]).get("crit", 1.0)
        if "Release Energy" in self.status_effects: luck_mult *= 1.25
        if "Basil Release Energy" in self.status_effects: luck_mult *= 1.80

        final_chance = max(0.0, min(1.0, (base_crit_chance + modifier_chance) * luck_mult))
        final_power = base_crit_power + modifier_power

        return random.random() < final_chance, final_power
        
    def receive_formula_damage(self, amount):
        dmg = float(amount)
        if self.is_defending:
            dmg *= 0.50
        dmg *= (1.0 - self.temp_values.get("damage_reduction", 0.0))
        
        dmg = max(1, min(9999, int(dmg)))
        protector = self.temp_values.get("covered_by")
        if protector and getattr(protector, "is_alive", False) and protector != self:
            redirect_dmg = int(dmg * 0.5)
            dmg -= redirect_dmg
            
            p_dmg = max(1, redirect_dmg)
            p_conversion = Emotions.get_self_damage_mana_conversion(protector.emotion)
            if p_conversion > 0:
                p_mp_dmg = int(p_dmg * p_conversion)
                p_actual_mp = min(protector.mana, p_mp_dmg)
                protector.mana -= p_actual_mp
                p_dmg -= p_actual_mp
            protector.hp -= max(1, int(p_dmg))
            
            if hasattr(self, "battle_announcements"):
                self.battle_announcements.append(f"\n<DELAY:0.5>  {Colors.CYAN}{protector.name} intercepted {redirect_dmg} damage for {self.name}!{Colors.RESET}")
                
            if protector.hp <= protector.max_hp * 0.30 and not protector.temp_values.get("im_here_triggered"):
                protector.temp_values["im_here_triggered"] = True
                protector.try_add_status("Defense++", 2)
                self.try_add_status("Defense++", 2)
                if hasattr(self, "battle_announcements"):
                    self.battle_announcements.append(f"\n<DELAY:0.5>  {Colors.YELLOW}{protector.name} stands their ground! Both gained Defense++!{Colors.RESET}")
                    
            if protector.hp <= 0:
                protector.hp = 0
                protector.is_alive = False
                
        conversion = Emotions.get_self_damage_mana_conversion(self.emotion)
        actual_mp_drain = 0
        if conversion > 0:
            mp_dmg = int(dmg * conversion)
            actual_mp_drain = min(self.mana, mp_dmg)
            self.mana -= actual_mp_drain
            dmg -= actual_mp_drain 

        if dmg > 0:
            dmg = max(1, int(dmg))
        else:
            dmg = 0
            
        self.hp -= dmg
        if self.hp <= 0:
            self.hp = 0
            self.is_alive = False

        if getattr(self, "on_hit_callback", None):
            self.on_hit_callback()
        
        total_damage = dmg + actual_mp_drain
        
        if actual_mp_drain > 0 and hasattr(self, "battle_announcements"):
            self.battle_announcements.append(f"\n<DELAY:0.3>  {Colors.CYAN}({actual_mp_drain} damage was absorbed by MP!){Colors.RESET}")

        return total_damage

    def process_turn_effects(self):
        """Applies damage and sets behavioral flags, but DOES NOT reduce duration yet!"""
        messages = []

        if "Poisoned" in self.status_effects:
            stacks = self.status_stacks.get("Poisoned", 1)
            dmg = max(1, int(self.max_hp * (0.04 * stacks)))
            self.hp -= dmg
            messages.append(f"{self.name} took {dmg} HP Poison damage (x{stacks}).")
            
        if "Burned" in self.status_effects:
            stacks = self.status_stacks.get("Burned", 1)
            dmg = max(1, int(self.max_hp * (0.03 * stacks)))
            self.hp -= dmg
            messages.append(f"{self.name} took {dmg} HP Burn damage (x{stacks}).")
            
        if "Bleeding" in self.status_effects:
            stacks = self.status_stacks.get("Bleeding", 1)
            dmg = max(1, int(self.max_hp * (0.05 * stacks)))
            self.hp -= dmg
            messages.append(f"{self.name} took {dmg} HP Bleeding damage (x{stacks}).")

        # Take It Slow Regeneration
        if self.temp_values.get("hp_regen"):
            h_amt = max(1, int(self.max_hp * self.temp_values["hp_regen"]))
            self.heal(h_amt)
            messages.append(f"{self.name} regenerated {h_amt} HP.")
        if self.temp_values.get("mp_regen"):
            m_amt = max(1, int(self.max_mana * self.temp_values["mp_regen"]))
            self.restore_mana(m_amt)
            messages.append(f"{self.name} regenerated {m_amt} MP.")

        self.skip_turn = False
        self.basic_attack_only = False

        if "Sleepy" in self.status_effects:
            self.skip_turn = True
            messages.append(f"{self.name} is Sleepy and cannot act.")
            
        if "Freeze" in self.status_effects:
            dmg = max(1, int(self.max_hp * 0.05))
            self.hp -= dmg
            self.skip_turn = True
            self.pending_freeze_slow = True
            messages.append(f"{Colors.CYAN}{self.name} is Frozen solid, losing {dmg} HP and their turn!{Colors.RESET}")
            
        if "Confused" in self.status_effects:
            self.basic_attack_only = True
            
        if "Dizzy" in self.status_effects:
            self.basic_attack_only = True

        return messages

    def tick_turn_effects(self):
        """Reduces duration of all effects. Called at the VERY END of the turn."""
        expired = []
        for effect in list(self.status_effects.keys()):
            self.status_effects[effect] -= 1
            if self.status_effects[effect] <= 0:
                expired.append(effect)

        for effect in expired:
            del self.status_effects[effect]
            if effect in self.status_stacks: del self.status_stacks[effect]

        for key in list(self.temp_effects.keys()):
            self.temp_effects[key] -= 1
            if self.temp_effects[key] <= 0:
                del self.temp_effects[key]
                if key in self.temp_values: del self.temp_values[key]

class Player(Character):
    def __init__(self, name, level=1, profile=None):
        self.profile = profile or OMORI_PROFILE
        stats = self.profile.stats_at_level(level)
        super().__init__(name, stats["hp"], stats["mana"], stats["atk"], stats["dfn"], stats["spd"])

        self.level = level
        self.xp = 0
        self.xp_to_next_level = 100 * level
        self.base_crit_chance = stats["crit_chance"]
        self.base_crit_power = stats["crit_power"]
        self.weapon = self.profile.weapon
        self.passive_name = self.profile.passive_name

        self.max_emotion_level = self.profile.max_emotion_level

        self.all_skills = {}
        self.equipped_skill_names =[]

        self.refresh_skills()
        self.equip_default_loadout()

        self.all_skills = {}
        self.equipped_skill_names =[]

        self.refresh_skills()
        self.equip_default_loadout()
        self.follow_up_skills = profile.follow_up_skills

    def gain_xp(self, amount):
        if self.level >= 50: return # Stop gaining XP at level 50!
        
        self.xp += amount
        print(f"  {Colors.GREEN}{self.name} gained {amount} XP!{Colors.RESET}")
        
        while self.xp >= self.xp_to_next_level and self.level < 50:
            self.xp -= self.xp_to_next_level
            self.level_up(1)
            
            if self.level == 50:
                print(f"  {Colors.YELLOW}⭐ MAX LEVEL REACHED! {self.name} is Level 50! ⭐{Colors.RESET}")
                self.xp = 0
            else:
                print(f"  {Colors.YELLOW}⭐ LEVEL UP! {self.name} reached Level {self.level}! ⭐{Colors.RESET}")
                self.xp_to_next_level = 100 * self.level
                
    def level_up(self, amount=1):
        self.level = min(50, self.level + max(1, int(amount)))
        stats = self.profile.stats_at_level(self.level)

        self.max_hp = stats["hp"]
        self.max_mana = stats["mana"]
        self.base_atk = stats["atk"]
        self.base_dfn = stats["dfn"]
        self.base_spd = stats["spd"]
        self.base_crit_chance = stats["crit_chance"]
        self.base_crit_power = stats["crit_power"]
        
        if self.equipment:
            self.max_hp += self.equipment.max_hp_bonus
            self.max_mana += self.equipment.max_mp_bonus

        self.hp = self.max_hp
        self.mana = self.max_mana

        self.refresh_skills(announce=True)
        return f"{self.name} reached level {self.level}."

    def refresh_skills(self, announce = False):
        if not hasattr(self, 'all_skills'): self.all_skills = {}
        newly_unlocked =[]
        for skill in self.profile.skill_book.values():
            if self.level >= skill.unlock_level:
                self.all_skills[skill.name] = skill
                
        if announce and newly_unlocked:
            print(f"  {Colors.PINK}★ {self.name} unlocked new skill(s): {', '.join(newly_unlocked)}!{Colors.RESET}")
            time.sleep(1.5)

    def equip_skill(self, skill_name):
        if skill_name not in self.all_skills:
            return f"{self.name} has not unlocked {skill_name}."
        if skill_name in self.equipped_skill_names:
            return f"{skill_name} is already equipped."
        if len(self.equipped_skill_names) >= 6:
            return f"{self.name} can only equip 6 skills."
        self.equipped_skill_names.append(skill_name)
        self.skills[skill_name] = self.all_skills[skill_name]
        return f"{self.name} equipped {skill_name}."

    def unequip_skill(self, skill_name):
        if skill_name in self.equipped_skill_names:
            self.equipped_skill_names.remove(skill_name)
            if skill_name in self.skills:
                del self.skills[skill_name]
            return f"{self.name} unequipped {skill_name}."
        return f"{skill_name} is not equipped."

    def equip_default_loadout(self):
        self.equipped_skill_names =[]
        self.skills = {}
        for skill_name in self.profile.default_loadout:
            if skill_name in self.all_skills and len(self.equipped_skill_names) < 6:
                self.equipped_skill_names.append(skill_name)
                self.skills[skill_name] = self.all_skills[skill_name]

    def available_skills(self):
        return list(self.equipped_skill_names)

