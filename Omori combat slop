SAVE_FILE = "omori_save.json"

def save_game(party):
    global PARTY_COINS, PARTY_INVENTORY, PARTY_EQUIPMENT_OWNED, RANDOM_BOSSES_DEFEATED
    
    data = {
        "coins": PARTY_COINS,
        "inventory": PARTY_INVENTORY,
        "equipment_owned": [eq.name for eq in PARTY_EQUIPMENT_OWNED],
        "bosses_defeated": list(RANDOM_BOSSES_DEFEATED),
        "party": {}
    }
    
    for p in party:
        p_data = {
            "level": p.level,
            "xp": p.xp,
            "equipped_skills": p.equipped_skill_names,
            "equipment": p.equipment.name if p.equipment else None
        }
        data["party"][p.name] = p_data
        
    try:
        with open(SAVE_FILE, "w") as f:
            json.dump(data, f, indent=4)
        print(f"\n  {Colors.GREEN}💾 Game Auto-Saved!{Colors.RESET}")
        time.sleep(0.8)
    except Exception as e:
        print(f"\n  {Colors.RED}[!] Failed to save game: {e}{Colors.RESET}")

def load_game(party):
    global PARTY_COINS, PARTY_INVENTORY, PARTY_EQUIPMENT_OWNED, RANDOM_BOSSES_DEFEATED
    
    if not os.path.exists(SAVE_FILE):
        return False
        
    try:
        with open(SAVE_FILE, "r") as f:
            data = json.load(f)
            
        PARTY_COINS = data.get("coins", 0)
        
        # Load Inventory
        PARTY_INVENTORY.clear()
        PARTY_INVENTORY.update(data.get("inventory", {}))
        
        # Load Equipment Inventory
        PARTY_EQUIPMENT_OWNED.clear()
        for eq_name in data.get("equipment_owned",[]):
            if eq_name in EQUIPMENT:
                PARTY_EQUIPMENT_OWNED.append(EQUIPMENT[eq_name])
                
        # Load Defeated Bosses
        RANDOM_BOSSES_DEFEATED.clear()
        RANDOM_BOSSES_DEFEATED.update(data.get("bosses_defeated",[]))
        
        # Load Party Stats, Skills, and Gear
        party_data = data.get("party", {})
        for p in party:
            if p.name in party_data:
                p_data = party_data[p.name]
                p.level = p_data.get("level", 1)
                p.xp = p_data.get("xp", 0)
                p.xp_to_next_level = 100 * p.level
                
                # Recalculate base stats based on loaded level
                stats = p.profile.stats_at_level(p.level)
                p.max_hp = stats["hp"]
                p.max_mana = stats["mana"]
                p.base_atk = stats["atk"]
                p.base_dfn = stats["dfn"]
                p.base_spd = stats["spd"]
                p.base_crit_chance = stats["crit_chance"]
                p.base_crit_power = stats["crit_power"]
                
                p.refresh_skills()
                
                # Re-equip skills
                p.equipped_skill_names =[]
                p.skills = {}
                for s_name in p_data.get("equipped_skills",[]):
                    if s_name in p.all_skills:
                        p.equip_skill(s_name)
                        
                # Re-equip gear
                eq_name = p_data.get("equipment")
                p.equipment = None
                if eq_name and eq_name in EQUIPMENT:
                    p.equipment = EQUIPMENT[eq_name]
                    p.max_hp += p.equipment.max_hp_bonus
                    p.max_mana += p.equipment.max_mp_bonus
                    
                p.hp = p.max_hp
                p.mana = p.max_mana
                
        print(f"  {Colors.GREEN}💾 Save Data Loaded Successfully!{Colors.RESET}")
        time.sleep(1.5)
        return True
    except Exception as e:
        print(f"  {Colors.RED}[!] Failed to load save: {e}{Colors.RESET}")
        time.sleep(2)
        return False

