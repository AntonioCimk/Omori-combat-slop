def backup_party_state(roster):
    """Creates a snapshot of the party's levels, XP, and skills before boss rush."""
    snapshot = {}
    for p in roster:
        snapshot[p.name] = {
            "level": p.level,
            "xp": p.xp,
            "skills": list(p.equipped_skill_names)
        }
    return snapshot

def restore_party_state(roster, snapshot):
    """Safely restores the party to strip away Level 50 auto-scaling and high-level skills."""
    for p in roster:
        if p.name in snapshot:
            data = snapshot[p.name]
            p.level = data["level"]
            p.xp = data["xp"]
            p.xp_to_next_level = 100 * p.level
            
            # Recalculate base stats for their true level
            stats = p.profile.stats_at_level(p.level)
            p.max_hp = stats["hp"]
            p.max_mana = stats["mana"]
            p.base_atk = stats["atk"]
            p.base_dfn = stats["dfn"]
            p.base_spd = stats["spd"]
            p.base_crit_chance = stats["crit_chance"]
            p.base_crit_power = stats["crit_power"]
            
            if p.equipment:
                p.max_hp += p.equipment.max_hp_bonus
                p.max_mana += p.equipment.max_mp_bonus
                
            p.hp = p.max_hp
            p.mana = p.max_mana
            
            # Rebuild available skills so they lose access to Level 50 skills
            p.all_skills = {}
            for skill in p.profile.skill_book.values():
                if p.level >= skill.unlock_level:
                    p.all_skills[skill.name] = skill
                    
            p.equipped_skill_names = []
            p.skills = {}
            for s in data["skills"]:
                if s in p.all_skills:
                    p.equip_skill(s)

def auto_scale_party(party, target_level):
    """Silently forces stats up to a target level without triggering level-up prints."""
    scaled = False
    for p in party:
        if p.level < target_level:
            p.level = target_level
            stats = p.profile.stats_at_level(p.level)
            p.max_hp = stats["hp"]
            p.max_mana = stats["mana"]
            p.base_atk = stats["atk"]
            p.base_dfn = stats["dfn"]
            p.base_spd = stats["spd"]
            p.base_crit_chance = stats["crit_chance"]
            p.base_crit_power = stats["crit_power"]
            
            if p.equipment:
                p.max_hp += p.equipment.max_hp_bonus
                p.max_mana += p.equipment.max_mp_bonus
            
            p.refresh_skills(announce=False)
            scaled = True
        p.hp = p.max_hp
        p.mana = p.max_mana
    if scaled:
        clear_screen()
        print(f"\n{Colors.YELLOW}{Colors.BOLD}[!] Party scaled to Level {target_level} for this fight!{Colors.RESET}")
        time.sleep(1.5)
        
