            "mana": min(999, self.base_mana + self.mana_growth * (level - 1)),
            "atk": min(999, self.base_atk + self.atk_growth * (level - 1)),
            "dfn": min(999, self.base_dfn + self.dfn_growth * (level - 1)),
            "spd": min(999, self.base_spd + self.spd_growth_amount * ((level - 1) // self.spd_growth_every)),
            "crit_chance": self.base_crit_chance + self.crit_growth_amount * ((level - 1) // self.crit_growth_every),
            "crit_power": self.base_crit_power + self.crit_power_growth_amount * ((level - 1) // self.crit_power_growth_every),
        }

class Skill:
    def __init__(self, name, cost, unlock_level=1, target_type="single_foe", kind="damage", data=None, priority=0):
        self.name = name
        self.cost = cost
        self.unlock_level = unlock_level
        self.target_type = target_type
        self.kind = kind
        self.data = data or {}
        self.priority = priority

    def execute(self, user, battle, target=None):
        if self.name != "Attack" and not Emotions.can_use_skills(user.emotion):
            return f"{user.name} is too shaken to use skills!"

        if user.mana < self.cost:
            return f"{user.name} does not have enough mana!"

        user.mana -= self.cost
        return SkillLibrary.execute_skill(self, user, battle, target)


class SkillLibrary:
    @staticmethod
    def _cleanup_redline(user, battle=None):
        low_hp = user.temp_values.get("redline_low_hp", False)
        
        for flag in ["redline_active", "redline_immunity", "redline_low_hp"]:
            if flag in user.temp_values: del user.temp_values[flag]
            if flag in user.temp_effects: del user.temp_effects[flag]
            
        for s in["Speed++", "Attack+"]:
            if s in user.status_effects:
                del user.status_effects[s]
                if hasattr(user, 'status_stacks') and s in user.status_stacks: del user.status_stacks[s]
                
        msg = f"\n<DELAY:0.8>  {Colors.RED}{user.name}'s Redline burns out, shedding its momentum!{Colors.RESET}"
        
        if low_hp:
            SkillLibrary._apply_status(user, "Crit power+", 99, battle=battle)
            SkillLibrary._apply_status(user, "Dizzy", 99, battle=battle)
            SkillLibrary._apply_status(user, "Exhausted", 99, battle=battle)
            msg += f"\n<DELAY:0.5>  {user.name} gained Crit power+, but became Dizzy and Exhausted!"
        else:
            SkillLibrary._apply_status(user, "Defense-", 99, battle=battle)
            SkillLibrary._apply_status(user, "Exhausted", 99, battle=battle)
            msg += f"\n<DELAY:0.5>  {user.name}'s Defense fell and they became Exhausted!"
            
        return msg

    @staticmethod
    def _base_damage(user, target, atk_mult, ignore_def=False, skill_data=None):
        skill_data = skill_data or {}
        stat_name = skill_data.get("stat", "atk")
        stat_val = user.get_effective_stat(stat_name)
        
        if skill_data.get("ignore_def_if_user_emotion") and Emotions.get_root(user.emotion) == skill_data["ignore_def_if_user_emotion"]:
            ignore_def = True
            
        dfn = 0 if ignore_def else target.get_effective_stat("dfn")
        if "fixed_damage" in skill_data: return skill_data["fixed_damage"]
            
        mult = atk_mult
        if skill_data.get("bonus_if_target_unstable") and Emotions.get_root(target.emotion) != "neutral":
            mult *= skill_data.get("bonus_multiplier", 1.4)
            
        if skill_data.get("tier_scaling"):
            root = Emotions.get_root(user.emotion)
            tier = Emotions.get_tier(user.emotion) if root != "neutral" else 0
            mult = 3.0 + tier if root == "neutral" else 4.0 + tier
            
        base_dmg = max(1, (stat_val * 2.0 * mult) - dfn)
   
        if "Dizzy" in user.status_effects:
            base_dmg = max(1, int(base_dmg * 0.5))
            
        return base_dmg

    @staticmethod
    def _finalize_damage(user, target, raw_damage, emotion_scale=True, battle=None, is_basic_attack=False, always_crit=False, hit_bonus=0.0, variance_override=None):
        # 1. APPLY VARIANCE 
        if variance_override:
            var_min, var_max = variance_override
        else:
            var_min, var_max = 0.80, 1.20
            
        dmg = max(1, int(raw_damage * random.uniform(var_min, var_max)))

        # 2. CALCULATE HIT/DODGE (Additive System)
        hit_chance = user.get_hit_rate() + hit_bonus 
        if getattr(user, 'has_passive', lambda x: False)("Eagle Eye"): hit_chance = 1.0

        # Evasion Calculation
        spd_attacker = user.get_effective_stat("spd")
        spd_target = target.get_effective_stat("spd")
        evasion = 0.05 + (0.50 * max(0, spd_target - spd_attacker) / max(1, spd_target + spd_attacker))
        
        if getattr(target, 'has_passive', lambda x: False)("Evasion"): evasion += 0.10
        if getattr(target, "temp_values", {}).get("slipstream_active"): evasion += 0.60 

        evasion = max(0.0, min(0.95, evasion))

        if "Freeze" in getattr(target, "status_effects", {}):
            evasion = 0.0

        # MISS CHECK
        if random.random() > (hit_chance - evasion):
            if battle: battle.last_hit_crit = False; battle.last_hit_weakness = False
            return 0, True  

        is_weakness = False

        # 3. APPLY MULTIPLIERS
        if emotion_scale:
            mult = Emotions.emotion_multiplier(user.emotion, target.emotion)
            dmg *= mult
            if mult > 1.0: is_weakness = True

        if getattr(user, 'has_passive', lambda x: False)("Bloodlust") and user.hp <= user.max_hp * 0.3:
            dmg *= 1.25

        # 4. CRITICAL HIT CALCULATION
        crit, crit_power = user.calculate_crit(user.base_crit_chance, user.base_crit_power)
        if always_crit or "Exposed" in target.status_effects: crit = True
        
        if crit: 
            dmg = int(dmg * (1 + crit_power)) + 2 

        dealt = target.receive_formula_damage(dmg)

        if battle and user in getattr(battle, 'party', []): battle.add_party_energy(1)
        
        if battle: battle.last_hit_crit = crit; battle.last_hit_weakness = is_weakness
        if getattr(target, 'has_passive', lambda x: False)("Stubborn Heart"):
            if target.hp < target.max_hp * 0.3 and not getattr(target, 'is_downed', False):
                target.apply_temp_effect("dfn_mult", 1.5, 1)
                if battle: target.battle_announcements.append(f"<DELAY:0.5>\n  {Colors.YELLOW}> {target.name}'s Stubborn Heart activated! Defense raised!{Colors.RESET}")

        return dealt, False
        
    @staticmethod
    def _apply_status(target, status, duration=None, battle=None):
        if isinstance(target, str):
            target, status = status, target
        n_status = effects.normalize(status)
        
        if battle and getattr(target, 'is_alive', False) and hasattr(target, "profile") and n_status in["Dizzy", "Freeze", "Sleepy"]:
            alive_party = battle.get_alive_party()
            afflicted =[p for p in alive_party if n_status in p.status_effects]
            if n_status in ["Freeze", "Dizzy"] and is_player:
                if len(afflicted) >= len(side) - 1 and target not in afflicted:
                    return f"{Colors.GREEN}{target.name} miraculously resisted {n_status} to protect the team!{Colors.RESET}"
            
            if n_status == "Sleepy":
                if len(afflicted) >= len(side) - 1 and target not in afflicted:
                    return f"{Colors.GREEN}{target.name} miraculously resisted Sleepy to prevent a wipeout!{Colors.RESET}"
            
            if n_status == "Confused":
                if len(afflicted) >= 1 and target not in afflicted:
                    return f"{Colors.GREEN}{target.name} miraculously kept their sanity!{Colors.RESET}"
                
        duration = duration if duration is not None else effects.get_duration(n_status)
        return target.try_add_status(n_status, duration)
        
    @staticmethod
    def _buff(target, status, duration=None, battle=None):
        return SkillLibrary._apply_status(target, status, duration, battle=battle)
        
    @staticmethod
    def _heal_target(source, target, pct_hp=0.0, pct_mana=0.0, fixed_hp=0, fixed_mana=0):
        hp_amount = fixed_hp if fixed_hp else int(target.max_hp * pct_hp)
        mana_amount = fixed_mana if fixed_mana else int(target.max_mana * pct_mana)

        if hasattr(source, "passive_name") and source.passive_name == "Calm Presence":
            if Emotions.get_root(source.emotion) == "happy":
                hp_amount = int(hp_amount * 1.10)

        hp_healed = target.receive_heal(hp_amount, source=source)
        mana_restored = target.restore_mana(mana_amount)

        if hasattr(source, 'add_threat'):
            source.add_threat(hp_healed * 1.5)

        return hp_healed, mana_restored
        
    @staticmethod
    def _append_hit_fx(base_str, battle):
