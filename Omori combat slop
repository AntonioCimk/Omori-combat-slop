@dataclass(frozen=True)
class ItemDef:
    name: str
    category: str
    target_scope: str
    price: int
    drop_rate: float
    cooldown: int = 0
    battle_only: bool = True
    effect: Dict[str, Any] = field(default_factory=dict)

    def use(self, user, battle, target=None):
        if self.battle_only and not battle.in_battle:
            return f"{self.name} can only be used in battle."

        if user.item_cooldowns.get(self.name, 0) > 0:
            return f"{self.name} is on cooldown for {user.item_cooldowns[self.name]} more turn(s)."

        targets = battle.resolve_targets(user, self.target_scope, target)
        if not targets:
            return "No valid targets."

        results =[]
        for tgt in targets:
            msg = resolve_item_effect(user, tgt, battle, self.effect)
            if msg:
                results.append(msg)

        if self.cooldown > 0:
            user.item_cooldowns[self.name] = self.cooldown

        if not results:
            return f"\n{user.name} used {self.name}, but nothing happened."

        return f"\n{user.name} used {self.name}!\n" + "\n".join(results)


@dataclass(frozen=True)
class EquipmentDef:
