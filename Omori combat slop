                break
            elif 1 <= choice <= len(cats):
                cat_name = cats[choice-1]
                shop_buy_menu(shop_inventory[cat_name], is_equip=False)
            elif choice == len(cats) + 1:
                shop_buy_menu(shop_equips, is_equip=True)
        except ValueError:
            pass

def shop_buy_menu(items_list, is_equip):
    global PARTY_COINS
    while True:
        clear_screen()
        print("\n" + Colors.GRAY + "-"*50 + Colors.RESET)
        print(f" Wallet: {Colors.YELLOW}{PARTY_COINS} Coins{Colors.RESET}")
        print(Colors.GRAY + "-"*50 + Colors.RESET)
        for i, item in enumerate(items_list):
            price = item.price if not is_equip else item.shop_price
            print(f"[{Colors.CYAN}{i+1}{Colors.RESET}] {item.name.ljust(22)} - {Colors.YELLOW}{price} Coins{Colors.RESET}")
        print(f"[{Colors.RED}0{Colors.RESET}] Back")

        choice = input(f"\n{Colors.BOLD}Buy #{Colors.RESET}> ").strip()
        if choice == "0":
            break
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(items_list):
                selected = items_list[idx]
                price = selected.price if not is_equip else selected.shop_price

                if PARTY_COINS >= price:
                    PARTY_COINS -= price
                    if is_equip:
                        PARTY_EQUIPMENT_OWNED.append(selected)
                        print(f"\n{Colors.GREEN}[!] Bought {selected.name}!{Colors.RESET}")
                    else:
                        PARTY_INVENTORY[selected.name] = PARTY_INVENTORY.get(selected.name, 0) + 1
                        print(f"\n{Colors.GREEN}[!] Bought {selected.name}! You now have {PARTY_INVENTORY[selected.name]}.{Colors.RESET}")
                else:
                    print(f"\n{Colors.RED}[!] Not enough coins!{Colors.RESET}")
                time.sleep(1.5)
        except ValueError:
            pass

