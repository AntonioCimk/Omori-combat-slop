class Emotions:
    NEUTRAL = "neutral"
    HAPPY = ["happy", "ecstatic", "manic"]
    SAD = ["sad", "depressed", "miserable"]
    ANGRY = ["angry", "enraged", "furious"]
    AFRAID = "afraid"
    STRESSED = "stressed out"
    OBSCURED = "obscured"

    # Canon Omori Stat Multipliers
    DATA = {
        "neutral":    {"atk": 1.0,  "dfn": 1.0,  "spd": 1.0,  "crit": 1.0, "hit": 0.0},

        "happy":      {"atk": 1.0,  "dfn": 1.0,  "spd": 1.25, "crit": 2.0, "hit": -0.10},
        "ecstatic":   {"atk": 1.0,  "dfn": 1.0,  "spd": 1.50, "crit": 3.0, "hit": -0.20},
        "manic":      {"atk": 1.0,  "dfn": 1.0,  "spd": 2.00, "crit": 4.0, "hit": -0.30},

        "sad":        {"atk": 1.0,  "dfn": 1.25, "spd": 0.80, "crit": 1.0, "hit": 0.0},
        "depressed":  {"atk": 1.0,  "dfn": 1.35, "spd": 0.65, "crit": 1.0, "hit": 0.0},
        "miserable":  {"atk": 1.0,  "dfn": 1.50, "spd": 0.50, "crit": 1.0, "hit": 0.0},

        "angry":      {"atk": 1.30, "dfn": 0.50, "spd": 1.0,  "crit": 1.0, "hit": 0.0},
        "enraged":    {"atk": 1.50, "dfn": 0.30, "spd": 1.0,  "crit": 1.0, "hit": 0.0},
        "furious":    {"atk": 2.00, "dfn": 0.15, "spd": 1.0,  "crit": 1.0, "hit": 0.0},

        "afraid":     {"atk": 1.0,  "dfn": 1.0,  "spd": 1.0,  "crit": 1.0, "hit": 0.0},
        "stressed out": {"atk": 1.20, "dfn": 0.90, "spd": 1.0,  "crit": 1.0, "hit": 0.0},

        "obscured":   {"atk": 1.0,  "dfn": 1.0,  "spd": 1.0,  "crit": 1.0, "hit": 0.0},
    }

    # Canon Damage to Juice (MP) conversion based on Sad Tier
    SELF_DAMAGE_MANA_CONVERSION = {
        "sad": 0.30,
        "depressed": 0.50,
        "miserable": 1.00
    }

    @staticmethod
    def normalize(emotion):
        if emotion is None: return "neutral"
        return str(emotion).strip().lower()

    @staticmethod
    def get_root(emotion):
        emotion = Emotions.normalize(emotion)
        if emotion in Emotions.HAPPY: return "happy"
        if emotion in Emotions.SAD: return "sad"
        if emotion in Emotions.ANGRY: return "angry"
        if emotion == Emotions.AFRAID: return "afraid"
        if emotion == Emotions.STRESSED: return "stressed out"
        if emotion == Emotions.OBSCURED: return "obscured"
        return "neutral"

    @staticmethod
    def get_tier(emotion):
        emotion = Emotions.normalize(emotion)
        if emotion in Emotions.HAPPY: return Emotions.HAPPY.index(emotion)
        if emotion in Emotions.SAD: return Emotions.SAD.index(emotion)
        if emotion in Emotions.ANGRY: return Emotions.ANGRY.index(emotion)
        return 0

    @staticmethod
    def get_stat_multiplier(emotion, stat):
        emotion = Emotions.normalize(emotion)
        return Emotions.DATA.get(emotion, Emotions.DATA["neutral"]).get(stat, 1.0)

    @staticmethod
    def get_hit_modifier(emotion):
        emotion = Emotions.normalize(emotion)
        return Emotions.DATA.get(emotion, Emotions.DATA["neutral"]).get("hit", 0.0)

    @staticmethod
    def get_damage_multiplier(attacker_emotion, defender_emotion):
        atk_root = Emotions.get_root(attacker_emotion)
        def_root = Emotions.get_root(defender_emotion)
        
        # Scaling magnitude is dictated by the DEFENDER's emotion tier
        def_tier = Emotions.get_tier(defender_emotion)

        # Afraid increases incoming damage by 1.5x from non-neutral attacks
        if def_root == "afraid" and atk_root != "neutral":
            return 1.50

        ADVANTAGE = [1.50, 2.00, 2.50]
        DISADVANTAGE = [0.80, 0.65, 0.50]

        if atk_root == "happy":
            if def_root == "angry": return ADVANTAGE[def_tier]
            if def_root == "sad": return DISADVANTAGE[def_tier]
        elif atk_root == "sad":
            if def_root == "happy": return ADVANTAGE[def_tier]
            if def_root == "angry": return DISADVANTAGE[def_tier]
        elif atk_root == "angry":
            if def_root == "sad": return ADVANTAGE[def_tier]
            if def_root == "happy": return DISADVANTAGE[def_tier]

        return 1.0

    @staticmethod
    def emotion_multiplier(attacker_emotion, defender_emotion):
        return Emotions.get_damage_multiplier(attacker_emotion, defender_emotion)

    @staticmethod
    def can_use_skills(emotion):
        emotion = Emotions.normalize(emotion)
        root = Emotions.get_root(emotion)
        return root not in ["afraid", "stressed out"]

    @staticmethod
    def is_obscured(emotion):
        return Emotions.get_root(emotion) == "obscured"

    @staticmethod
    def get_self_damage_mana_conversion(emotion):
        emotion = Emotions.normalize(emotion)
        return Emotions.SELF_DAMAGE_MANA_CONVERSION.get(emotion, 0.0)

    @staticmethod
    def get_status_summary(emotion):
        emotion = Emotions.normalize(emotion)
        if emotion == "happy": return "+25% Speed, 2x Crit Chance, -10% Hit Rate"
        if emotion == "ecstatic": return "+50% Speed, 3x Crit Chance, -20% Hit Rate"
        if emotion == "manic": return "+100% Speed, 4x Crit Chance, -30% Hit Rate"
        
        if emotion == "sad": return "+25% Defense, -20% Speed, 30% dmg to MP"
        if emotion == "depressed": return "+35% Defense, -35% Speed, 50% dmg to MP"
        if emotion == "miserable": return "+50% Defense, -50% Speed, 100% dmg to MP"
        
        if emotion == "angry": return "+30% Attack, -50% Defense"
        if emotion == "enraged": return "+50% Attack, -70% Defense"
        if emotion == "furious": return "+100% Attack, -85% Defense"
        
        if emotion == "afraid": return "Takes 1.5x damage from emotions. No skills."
        if emotion == "stressed out": return "+20% Attack, -10% Defense. No skills."
        if emotion == "obscured": return "Emotion hidden."
        
        return "Neutral"

class effects:
    Positive_effects = {
        "Attack+", "Defense+", "Speed+", "Attack++", "Defense++", "Speed++", "Attack+++", "Defense+++", "Speed+++",
        "Focus+", "Crit power+", "Focus++", "Crit power++", "Focus+++", "Crit power+++",
        "Feel Fine", "Friendship", "Release Energy", "Basil Release Energy"
    }

    Negative_effects = {
        "Attack-", "Defense-", "Speed-", "Attack--", "Defense--", "Speed--", "Attack---", "Defense---", "Speed---",
        "Poisoned", "Burned", "Bleeding", "Freeze", "Distracted", "Distracted--", "Distracted---",
        "Exhausted", "Exhausted--", "Exhausted---", "Confused", "Dizzy", "Sleepy", "Obscured", "Blind", "Exposed"
    }

    ALIASES = {
        "Freezed": "Freeze", "Frozen": "Freeze",
        "Attack–": "Attack--", "Defense–": "Defense--", "Speed–": "Speed--"
    }

    DURATIONS = {
        "Attack+": 6, "Defense+": 6, "Speed+": 6, "Attack++": 6, "Defense++": 6, "Speed++": 6, "Attack+++": 6, "Defense+++": 6, "Speed+++": 6,
        "Focus+": 6, "Crit power+": 6, "Focus++": 6, "Crit power++": 6, "Focus+++": 6, "Crit power+++": 6,
        "Feel Fine": 2, "Friendship": 2,
        "Attack-": 6, "Defense-": 6, "Speed-": 6, "Attack--": 6, "Defense--": 6, "Speed--": 6, "Attack---": 6, "Defense---": 6, "Speed---": 6,
        
        "Poisoned": 4, "Burned": 3, "Bleeding": 2, "Freeze": 1, 
        "Distracted": 5, "Distracted--": 5, "Distracted---": 5,
        "Exhausted": 5, "Exhausted--": 5, "Exhausted---": 5,
        "Confused": 2, "Dizzy": 2, "Sleepy": 3, "Obscured": 3, "Blind": 2, "Exposed": 2
    }

    STAT_MODS = {
        "Attack+": {"atk": +0.15}, "Attack++": {"atk": +0.30}, "Attack+++": {"atk": +0.45},
        "Defense+": {"dfn": +0.15}, "Defense++": {"dfn": +0.30}, "Defense+++": {"dfn": +0.45},
        "Speed+": {"spd": +0.10}, "Speed++": {"spd": +0.20}, "Speed+++": {"spd": +0.30},
        "Focus+": {"crit": +0.10}, "Focus++": {"crit": +0.20}, "Focus+++": {"crit": +0.30},
        "Crit power+": {"crit_power": +0.20}, "Crit power++": {"crit_power": +0.40}, "Crit power+++": {"crit_power": +0.60},
        
        "Attack-": {"atk": -0.15}, "Attack--": {"atk": -0.30}, "Attack---": {"atk": -0.45},
        "Defense-": {"dfn": -0.15}, "Defense--": {"dfn": -0.30}, "Defense---": {"dfn": -0.45},
        "Speed-": {"spd": -0.15}, "Speed--": {"spd": -0.30}, "Speed---": {"spd": -0.45},
        "Distracted": {"crit": -0.15}, "Distracted--": {"crit": -0.30}, "Distracted---": {"crit": -0.45},
        "Exhausted": {"crit_power": -0.20}, "Exhausted--": {"crit_power": -0.40}, "Exhausted---": {"crit_power": -0.60},
    }

    # CAPS (non emotion)
    # These are delta caps, not final-stat caps
    # Example: +1.00 = +100%, -0.80 = -80%
    CAPS = {
        "atk": (-0.80, +1.00),
        "dfn": (-0.80, +1.00),
        "spd": (-0.50, +0.80),
        "crit": (-0.40, +0.50),
        "crit_power": (-0.50, +0.70),
    }
    # DOT DAMAGE (per turn)
    DOT = {
        "Poisoned": 0.04,
        "Burned": 0.03,
        "Bleeding": 0.05,
    }
  
    # CONTROL / SPECIAL RULES
    ACTION_SKIP = {"Sleepy", "Freeze"}
    BASIC_ATTACK_ONLY = {"Confused", "Dizzy"}

    SPECIAL_RULES = {
        "Freeze": {
            "skip_turn": True,
            "next_turn_speed_penalty": -0.10,   # apply this after the freeze turn
            "duration": 1
        },
        "Confused": {
            "skip_skill_use": True,
            "force_basic_attack": True,
            "self_or_ally_hit_chance": 0.50,
            "duration": 2
        },
        "Dizzy": {
            "force_basic_attack": True,
            "damage_mult": 0.50,
            "duration": 2
        },
        "Sleepy": {
            "skip_turn": True,
            "duration": 3
        }
    }
    
    # HELPERS
    @staticmethod
    def normalize(name):
        if name is None:
            return None
        name = str(name).strip()
        return effects.ALIASES.get(name, name)

    @staticmethod
    def is_positive(name):
        return effects.normalize(name) in effects.Positive_effects

    @staticmethod
    def is_negative(name):
        return effects.normalize(name) in effects.Negative_effects

    @staticmethod
    def get_duration(name):
        return effects.DURATIONS.get(effects.normalize(name), 0)

    @staticmethod
    def get_data(name):
        name = effects.normalize(name)
        return {
            "duration": effects.DURATIONS.get(name, 0),
            "stat_mod": effects.STAT_MODS.get(name, {}),
            "dot": effects.DOT.get(name, 0),
            "special": effects.SPECIAL_RULES.get(name, {})
        }

    @staticmethod
    def clamp_delta(stat, delta):
        low, high = effects.CAPS.get(stat, (-999, 999))
        return max(low, min(high, delta))

    @staticmethod
    def calculate_stat_modifiers(active_effects):
        """
        Returns total non-emotion delta modifiers:
        {"atk": x, "dfn": x, "spd": x, "crit": x, "crit_power": x}
        """
        total = {"atk": 0.0, "dfn": 0.0, "spd": 0.0, "crit": 0.0, "crit_power": 0.0}

        for effect in active_effects:
            effect = effects.normalize(effect)
            if effect in effects.STAT_MODS:
                for stat, val in effects.STAT_MODS[effect].items():
                    total[stat] += val

        for stat in total:
            total[stat] = effects.clamp_delta(stat, total[stat])

        return total

    @staticmethod
    def is_incapacitated(status_effects):
        status_effects = {effects.normalize(s) for s in status_effects}
        return ("Sleepy" in status_effects) or ("Freeze" in status_effects)

    @staticmethod
    def is_dizzy(status_effects):
        status_effects = {effects.normalize(s) for s in status_effects}
        return "Dizzy" in status_effects

    @staticmethod
    def is_confused(status_effects):
        status_effects = {effects.normalize(s) for s in status_effects}
        return "Confused" in status_effects

    @staticmethod
    def get_freeze_speed_penalty():
        return -0.10

    @staticmethod
    def process_effects(character):
        messages = []
        expired =[]

        # DOT damage
        for effect, percent in effects.DOT.items():
            if effect in character.status_effects:
                dmg = max(1, int(character.max_hp * percent))
                character.hp -= dmg
                messages.append(f"{character.name} took {dmg} damage from {effect}.")

        # Special start-of-turn flags
        character.skip_turn = False
        character.basic_attack_only = False

        if "Sleepy" in character.status_effects:
            character.skip_turn = True
            messages.append(f"{character.name} is sleepy and cannot act.")

        if "Freeze" in character.status_effects:
            character.skip_turn = True
            character.pending_freeze_slow = True
            messages.append(f"{character.name} is frozen and loses their turn.")

        if "Confused" in character.status_effects:
            character.basic_attack_only = True

        if "Dizzy" in character.status_effects:
            character.basic_attack_only = True

        # Tick durations
        for effect in list(character.status_effects.keys()):
            character.status_effects[effect] -= 1
            if character.status_effects[effect] <= 0:
                expired.append(effect)

        for effect in expired:
            del character.status_effects[effect]

        for key in list(character.temp_effects.keys()):
            character.temp_effects[key] -= 1
            if character.temp_effects[key] <= 0:
                del character.temp_effects[key]
                if key in character.temp_values:
                    del character.temp_values[key]



        return messages

