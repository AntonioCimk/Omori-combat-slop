    def interactive_follow_up(self, initiator, valid_follow_ups, target):
        self.last_observed_target = target
        deadline = getattr(self, "_brutal_deadline", None)
        brutal   = (deadline is not None)

        def _remaining(): return max(0.0, deadline - time.time()) if brutal else 9999.0
        def _inp(prompt):
            if not brutal: return input(prompt), False
            left = _remaining()
            if left <= 0: return "", True
            return timed_input_countdown(prompt, left)
            
        self.print_turn_header(initiator, "FOLLOW-UP OPPORTUNITY!")
        print(f"[{Colors.RED}0{Colors.RESET}] Ignore (Save Energy)")
        
        for i, fu in enumerate(valid_follow_ups):
            skill = fu['skill']
            cost = fu.get('cost', skill.cost)
            resp_name = fu['responder'].name if fu['responder'] else "EVERYONE"
            
            print(f"[{Colors.CYAN}{i+1}{Colors.RESET}] Tag {resp_name}: {skill.name} ({Colors.YELLOW}-{cost} Energy{Colors.RESET})")
            
        while True:
            if brutal and _remaining() <= 0:
                print("  ⏱ Follow-up window closed (time ran out).")
                break

            choice, timed_out = _inp("Combo #> ")
            if timed_out:
                print("  ⏱ Follow-up window closed.")
                break

            choice = choice.strip()
            if choice == "0":
                print("\n  Follow-up ignored.")
                time.sleep(1.0)
                break
            try:
                idx = int(choice) - 1
                if 0 <= idx < len(valid_follow_ups):
                    fu = valid_follow_ups[idx]
                    responder = fu["responder"]
                    skill = fu["skill"]
                    cost = fu.get("cost", skill.cost)
                    fu_target = target
                    
                    if skill.target_type == "single_ally":
                        prompter = responder if responder else initiator
                        fu_target = self.prompt_target(prompter, side="allies", deadline=deadline)
                        if not fu_target: 
                            # If they canceled, redraw the combo menu
                            self.print_turn_header(initiator, "FOLLOW-UP OPPORTUNITY!")
                            print(f"[{Colors.RED}0{Colors.RESET}] Ignore (Save Energy)")
                            for j, f in enumerate(valid_follow_ups):
                                r_name = f['responder'].name if f['responder'] else "EVERYONE"
                                f_cost = f.get('cost', f['skill'].cost)
                                print(f"[{Colors.CYAN}{j+1}{Colors.RESET}] Tag {r_name}: {f['skill'].name} ({Colors.YELLOW}-{f_cost} Energy{Colors.RESET})")
                            continue
                            
                    # Spend resources
                    self.spend_party_energy(cost)
                    self.momentum += 0.2
                    
                    initiator_has_followed_up = True
                    if responder: 
                        responder.has_followed_up = True 
                    elif skill.target_type == "Team":
                        for p in self.party:
                            p.has_followed_up = True

                    self.current_responder = responder
                    result = SkillLibrary.execute_skill(skill, initiator, self, fu_target)
                    self.current_responder = None
                    
                    clear_screen()
                    self.print_battle_status()
                    print(f"\n  {Colors.PINK}→ FOLLOW-UP: {initiator.name} uses {skill.name}!{Colors.RESET}")
                    if result:
                        animated_print(f"\n{result}")
                        time.sleep(3.0)
                        break
            except ValueError:
                pass
            print("Invalid input.")

    def print_battle_status(self):
        border = f"{Colors.DARK_GRAY}━" * 105 + Colors.RESET
        print("\n" + border)
        print(f"  {Colors.BOLD}BATTLE:{Colors.RESET} {Colors.CYAN}{getattr(self, 'battle_type', 'Encounter')}{Colors.RESET} | {Colors.BOLD}DIFFICULTY:{Colors.RESET} {Colors.RED if DIFFICULTY == 'Brutal' else Colors.GREEN}{DIFFICULTY}{Colors.RESET}")
        print(f"  {Colors.BOLD}TEAM ENERGY:{Colors.RESET} {self.energy_bar_display()}")
        print(border)

        def get_emo_color(emo, is_omori=False):
            emo_norm = emo.lower()
            # Sad Tier
            if emo_norm == "sad": return Colors.LIGHT_CYAN
            if emo_norm == "depressed": return Colors.BOLD + Colors.CYAN
            if emo_norm == "miserable": return Colors.BOLD + Colors.DEEP_CYAN
            # Angry Tier
            if emo_norm == "angry": return Colors.ORANGE
            if emo_norm == "enraged": return Colors.LIGHT_RED
            if emo_norm == "furious": return Colors.BOLD + Colors.RED
            # Happy Tier
            if emo_norm == "happy": return Colors.YELLOW
            if emo_norm == "ecstatic": return Colors.PINK
            if emo_norm == "manic": return Colors.LIGHT_PURPLE
            # Special
            if emo_norm == "obscured": return Colors.PURPLE
            if emo_norm == "afraid": return Colors.LIGHT_GRAY
            if emo_norm == "stressed out": return Colors.DARK_GRAY

            return Colors.WHITE

        def format_char(c, is_player):
            is_omori = (c.name == "Omori")

            # Determine base colors
            c_name_color = Colors.GRAY if is_omori else Colors.BOLD
            c_icon_color = Colors.GRAY if is_omori else (Colors.CYAN if is_player else Colors.RED)

            icon = f"{c_icon_color}{'✦' if is_player else '❖'}{Colors.RESET}"
            name_str = f"{c_name_color}{c.name.ljust(18)}{Colors.RESET}"

            if not c.is_alive or getattr(c, "is_downed", False):
                return f"   ☠  {name_str} | {Colors.DARK_GRAY}[ DEFEATED ]{Colors.RESET}"

            if getattr(c, "is_obscured", lambda: False)():
                return f"   {icon}  {name_str} | HP: ???       | MP: ???     | Emo: ???       | B: ??? | D: ???"

            # Formulate HP
            hp_val = f"{c.hp}/{c.max_hp}"
            hp_color = Colors.GRAY if is_omori else (Colors.GREEN if c.hp > (c.max_hp * 0.3) else Colors.RED)
            hp_str = f"{hp_color}{hp_val.ljust(11)}{Colors.RESET}"

            # Formulate MP
            mp_val = f"{c.mana}/{c.max_mana}"
            mp_color = Colors.GRAY if is_omori else Colors.CYAN
            mp_str = f"{mp_color}{mp_val.ljust(9)}{Colors.RESET}"

            # Formulate Emotion
            emo_val = c.emotion.capitalize()
            emo_str = f"{get_emo_color(c.emotion, is_omori)}{emo_val.ljust(10)}{Colors.RESET}"

            # Formulate Buffs / Debuffs
            buffs =[e for e in getattr(c, "status_effects", {}) if effects.is_positive(e)]
            debuffs =[e for e in getattr(c, "status_effects", {}) if effects.is_negative(e)]
            if "damage_reduction" in getattr(c, 'temp_effects', {}): buffs.append("Shield")
            if "Desperation" in getattr(c, 'temp_effects', {}): buffs.append("Desperation")

            b_val = ", ".join(buffs) if buffs else "-"
            d_val = ", ".join(debuffs) if debuffs else "-"

            b_str = f"{Colors.GRAY if is_omori else Colors.GREEN}{b_val}{Colors.RESET}"
            d_str = f"{Colors.GRAY if is_omori else Colors.RED}{d_val}{Colors.RESET}"

            buffs =[]
            for e in getattr(c, "status_effects", {}):
                if effects.is_positive(e):
                    stacks = getattr(c, "status_stacks", {}).get(e, 1)
                    buffs.append(f"{e} (x{stacks})" if stacks > 1 else e)
                    
            debuffs =[]
            for e in getattr(c, "status_effects", {}):
                if effects.is_negative(e):
                    stacks = getattr(c, "status_stacks", {}).get(e, 1)
                    debuffs.append(f"{e}(x{stacks})" if stacks > 1 else e)

            return f"   {icon}  {name_str} | HP: {hp_str} | MP: {mp_str} | Emo: {emo_str} | B: {b_str} | D: {d_str}"

        print(f" {Colors.BOLD}[ ENEMY UNITS ]{Colors.RESET}")
        for f in self.enemies:
            print(format_char(f, False))

        print(f"\n {Colors.BOLD}[ PLAYER TEAM ]{Colors.RESET}")
        for p in self.party:
            print(format_char(p, True))
        print(border)

