def get_item_desc(item):
    if not item: return "Unknown Item."
    eff = item.effect
    k = eff.get("kind", "")
    parts =[]
    scope_str = "ALL allies" if item.target_scope == "all_allies" else "target"

    if "heal_hp" in eff: parts.append(f"Heals {int(eff['heal_hp']*100)}% HP.")
    if "restore_mana" in eff: parts.append(f"Restores {int(eff['restore_mana']*100)}% MP.")
    if k == "heal_hp" or k == "heal_hp_all": parts.append(f"Heals {int(eff.get('pct',0)*100)}% HP.")
    if k == "restore_mana" or k == "restore_mana_all": parts.append(f"Restores {int(eff.get('pct',0)*100)}% MP.")
    if k == "revive": parts.append(f"Revives ally ({int(eff.get('hp_pct',0)*100)}% HP).")
    
    if k == "emotion" or "emotion" in eff: parts.append(f"Makes {scope_str} {format_emo(eff.get('emotion',''))}.")
    
    if k == "damage": parts.append(f"Deals {int(eff.get('pct',0)*100)}% ATK damage.")
    
    if "add_status" in eff: parts.append(f"Grants {eff['add_status']}.")
    if "add_statuses" in eff: parts.append(f"Grants {', '.join(s[0] for s in eff['add_statuses'])}.")
    if "apply_status" in eff: parts.append(f"Inflicts {eff['apply_status']} (Can stack).")
    
    if k == "clear_obscured_and_emotion": parts.append("Clears emotion and Obscured state.")
    if "remove_one_debuff" in eff or k == "remove_one_debuff": parts.append("Cures one debuff.")
    if "remove_all_debuffs" in eff or k == "remove_all_debuffs": parts.append("Cures ALL debuffs.")
    if "add_immunity" in eff: parts.append("Grants debuff immunity.")

    return " ".join(parts) if parts else "Consumable item."

def use_item_out_of_battle(item_name, user, target):
    """Uses potions and foods safely while exploring"""
    item = ITEMS.get(item_name)
    if not item: return
    if item.battle_only:
        print(f"\n{Colors.RED}[!] {item.name} can only be used during combat!{Colors.RESET}")
        time.sleep(1.5); return

    result = resolve_item_effect(user, target, None, item.effect)
    PARTY_INVENTORY[item_name] -= 1
    print(f"\n{Colors.GREEN}[!] {result}{Colors.RESET}")
    time.sleep(1.5)

