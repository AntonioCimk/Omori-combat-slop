def format_emo(emo_name):
    emo_lower = emo_name.lower()
    color = EMOTION_COLORS.get(emo_lower, Colors.WHITE)
    return f"{color}{emo_name.capitalize()}{Colors.RESET}"
    
def clear_screen():
    # 1. Try standard OS terminal clear
    os.system('cls' if os.name == 'nt' else 'clear')
    
    # 2. ANSI Escape Codes (Resets terminal, clears screen, moves cursor to top)
    sys.stdout.write('\033c\033[2J\033[H')
    sys.stdout.flush()
    
    print('\n' * 40)
    sys.stdout.write('\033[H')
    sys.stdout.flush()

def animated_print(text):
    """Prints text normally, but pauses whenever it sees a <DELAY:x> tag"""
    if not text:
        return
    parts = text.split("<DELAY:")
    sys.stdout.write(parts[0])
    sys.stdout.flush()
    for part in parts[1:]:
        try:
            delay_str, rest = part.split(">", 1)
            time.sleep(float(delay_str))
            sys.stdout.write(rest)
        except ValueError:
            sys.stdout.write("<DELAY:" + part)
        sys.stdout.flush()
    print() 
        
