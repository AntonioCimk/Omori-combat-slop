    def check_comeback_mechanics(self):
        standing_members =[p for p in self.party if not getattr(p, "is_downed", False)]
        if len(standing_members) == 1:
            last_stander = standing_members[0]
            if "Desperation" not in last_stander.temp_effects:
                print(f"\n[!] {last_stander.name} is the last one standing! DESPERATION activated!")
                last_stander.apply_temp_effect("Desperation", 1, 3)
                self.add_party_energy(20)
                last_stander.temp_values["damage_reduction"] = 0.3
                clear_screen()
                self.print_battle_status()
                print(f"\n{Colors.RED}[!] {last_stander.name} is the last one standing! DESPERATION activated!{Colors.RESET}")
                time.sleep(2.0)

    def run(self):
        self.start_battle()
        print("\nBATTLE START!")

        while self.in_battle:
            self.turn_count += 1
            print(f"\n--- ROUND {self.turn_count} ---")
            self.start_turn_reset()

            combatants = self.get_all_combatants()

            for combatant in combatants:
                if self.check_victory():
                    break

                if not combatant.is_alive or getattr(combatant, "is_downed", False):
                    continue
                msgs = combatant.process_turn_effects()
                if msgs:
                    clear_screen()
                    self.print_battle_status()
                    print("\n" + "\n".join([f"  {m}" for m in msgs]))
                    time.sleep(2.0)

                
                if getattr(combatant, "skip_turn", False):
                    clear_screen()
                    self.print_battle_status()
                    print(f"\n  {Colors.RED}>>> {combatant.name} cannot act this turn! <<<{Colors.RESET}")
                    time.sleep(1.5)
                    combatant.tick_turn_effects()
                    continue

                
                if "Confused" in combatant.status_effects:
                    clear_screen()
                    self.print_battle_status()
                    print(f"\n{Colors.PURPLE}==> {combatant.name.upper()} IS CONFUSED! <=={Colors.RESET}")
                    
                    all_targets = [c for c in self.party + self.enemies if c.is_alive and not getattr(c, "is_downed", False)]
                    target = random.choice(all_targets) if all_targets else combatant
                    
                    if hasattr(combatant, 'all_skills'): 
                        result = self.use_skill(combatant, "Attack", target)
                    else: 
                        raw = SkillLibrary._base_damage(combatant, target, 1.0)
                        dealt, missed = SkillLibrary._finalize_damage(combatant, target, raw, battle=self, is_basic_attack=True)
                        action_txt = Narrator.attack(combatant.name, target.name)
                        
                        dmg_str = SkillLibrary._dmg_str(target, dealt)
                        if missed: result = f"{action_txt}\n<DELAY:0.8>  ...but missed entirely!"
                        else: result = SkillLibrary._append_hit_fx(f"{action_txt}\n<DELAY:0.8>  ...dealing {dmg_str} damage!", self)
                    
                    animated_print(f"\n{result}")
                    time.sleep(2.5)
                    combatant.tick_turn_effects()
                    continue

                
                if hasattr(combatant, "take_turn"):
                    clear_screen()
                    self.print_battle_status()
                    print(f"\n{Colors.RED}==> {combatant.name.upper()}'S TURN <=={Colors.RESET}")
                    combatant.take_turn(self)
                    for c in self.party + self.enemies:
                        if getattr(c, 'battle_announcements', []):
                            animated_print("".join(c.battle_announcements))
                            c.battle_announcements.clear()
                    time.sleep(2.5)
                else:
                    self.player_take_turn(combatant)
                    
                combatant.tick_turn_effects()
                                  
        for p in self.party:
                p.reset_state()

