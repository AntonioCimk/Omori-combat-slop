        elif kind == "immunity":
            user.immunity_charges += self.effect.get("charges", 0)


def resolve_item_effect(user, target, battle, effect):
    kind = effect.get("kind")
    msg_parts =[]

    if "heal_hp" in effect or kind in ["heal_hp", "heal_hp_all"]:
        pct = effect.get("heal_hp", effect.get("pct", 0.0))
        healed = target.heal(int(target.max_hp * pct))
        msg_parts.append(f"<DELAY:0.6>\n  {target.name}'s wounds close, recovering {healed} HP!")

    if "restore_mana" in effect or kind in["restore_mana", "restore_mana_all"]:
        pct = effect.get("restore_mana", effect.get("pct", 0.0))
        restored = target.restore_mana(int(target.max_mana * pct))
        msg_parts.append(f"<DELAY:0.6>\n  {target.name} feels refreshed, restoring {restored} MP!")

    if effect.get("remove_all_debuffs") or kind == "remove_all_debuffs":
        removed = target.remove_all_debuffs()
        if removed: msg_parts.append(f"<DELAY:0.6>\n  {target.name} was cleansed of all negative afflictions!")

    if effect.get("remove_one_debuff") or kind == "remove_one_debuff":
        removed = target.remove_one_debuff()
        if removed: msg_parts.append(f"<DELAY:0.6>\n  {target.name} was successfully cured of {removed}!")

    if "add_statuses" in effect:
        for stat, dur in effect["add_statuses"]:
            stat_msg = SkillLibrary._apply_status(target, stat, dur, battle=battle)
            msg_parts.append(f"<DELAY:0.5>\n  > {stat_msg}")

    if "add_status" in effect:
        stat_msg = SkillLibrary._apply_status(target, effect["add_status"], effect.get("status_duration", 2), battle=battle)
        msg_parts.append(f"<DELAY:0.5>\n  > {stat_msg}")
     
    if "temp_effect" in effect:
        for k, v in effect["temp_effect"].items():
            target.apply_temp_effect(k, v, effect.get("temp_duration", 1))
        msg_parts.append(f"<DELAY:0.5>\n  > {target.name} gained a temporary stat buff!")

    if kind == "revive":
        if target.is_alive and not getattr(target, 'is_downed', False):
            if "alt_heal_hp" in effect: 
                target.heal(int(target.max_hp * effect["alt_heal_hp"]))
                target.restore_mana(int(target.max_mana * effect["alt_mana"]))
                msg_parts.append(f"<DELAY:0.6>\n  {target.name} is already conscious, but recovered HP and MP!")
            else:
                return f"<DELAY:0.5>\n  {target.name} is not downed. The item had no effect."
        else:
            if "fixed_hp" in effect: target.hp = effect["fixed_hp"]
            else: target.hp = max(1, int(target.max_hp * effect["hp_pct"]))
            target.mana += int(target.max_mana * effect.get("mana_pct", 0.0))
            target.is_downed = False
            target.is_alive = True
            target.set_emotion("neutral") 
            msg_parts.append(f"<DELAY:0.8>\n  {target.name} gasped for air and was miraculously revived!")

    if kind == "emotion":
        target.set_emotion(effect["emotion"], 999)
        msg_parts.append(f"<DELAY:0.6>\n  {target.name} suddenly became {format_emo(effect['emotion'])}!")

    if kind == "clear_obscured_and_emotion":
        target.set_emotion("neutral")
        if "Obscured" in target.status_effects: del target.status_effects["Obscured"]
        msg_parts.append(f"<DELAY:0.6>\n  {target.name}'s vision cleared, returning to a Neutral state.")

    if kind == "damage":
        spd_attacker = user.get_effective_stat("spd")
        spd_target = target.get_effective_stat("spd")
        dodge_chance = 0.05 + (0.50 * (spd_target - spd_attacker) / max(1, spd_target + spd_attacker))
        dodge_chance = max(0.05, min(0.40, dodge_chance))

        if random.random() <= dodge_chance:
            return f"<DELAY:0.6>\n  {target.name} swiftly dodged the item!"

        item_base_power = 15 + (user.level * 3)
        mult = effect["pct"]
        if effect.get("use_emotion_advantage", True): mult *= Emotions.emotion_multiplier(user.emotion, target.emotion)
        if effect.get("bonus_if_target_dizzy") and "Dizzy" in target.status_effects: mult *= effect.get("bonus_multiplier", 1.5)
        if effect.get("bonus_if_target_emotion") and Emotions.get_root(target.emotion) == effect.get("bonus_if_target_emotion"): mult *= effect.get("bonus_multiplier", 1.5)
        if effect.get("bonus_if_user_emotion") and Emotions.get_root(user.emotion) == effect.get("bonus_if_user_emotion"): mult *= effect.get("bonus_multiplier", 1.5)
        if effect.get("bonus_if_unstable") and Emotions.get_root(target.emotion) != "neutral": mult *= effect.get("bonus_multiplier", 1.5)
        if effect.get("bonus_if_target_low_hp") and target.hp <= target.max_hp * effect.get("low_hp_threshold", 0.3): mult *= effect.get("bonus_multiplier", 1.5)

        base_dmg = max(1, (item_base_power * 2.0 * mult) - target.get_effective_stat("dfn"))
        
        # ITEM VARIANCE
        root_emo = Emotions.get_root(user.emotion)
        if root_emo == "angry": variance = random.uniform(0.75, 1.25)
        elif root_emo == "sad": variance = random.uniform(0.95, 1.05)
        elif root_emo == "happy": variance = random.uniform(0.85, 1.15)
        else: variance = random.uniform(0.90, 1.10)
        
        damage = max(1, int(base_dmg * variance))
        dealt = target.receive_formula_damage(damage)
        
        hit_msg = f"<DELAY:0.6>\n  The item blasts {target.name} for {SkillLibrary._dmg_str(target, dealt)} damage!"
        msg_parts.append(SkillLibrary._append_hit_fx(hit_msg, battle))

        if "apply_status" in effect:
            if random.random() <= effect.get("apply_status_chance", 1.0):
                stat_msg = SkillLibrary._apply_status(target, effect["apply_status"], effect.get("status_duration", 2), battle=battle)
                msg_parts.append(f"<DELAY:0.6>\n  > {stat_msg}")
                
            if battle:
                for c in battle.party + battle.enemies:
                     if getattr(c, 'battle_announcements', []):
                         for msg in c.battle_announcements:
                               msg_parts.append(msg)
                               c.battle_announcements.clear()

    return "".join(msg_parts)
                    
# TIMED INPUT HELPER

def timed_input_countdown(prompt_base, timeout):
    """
    Timed input with a live [Xs] countdown rewritten into the prompt each second.
    Prints a warning line the moment 5 seconds remain.
    Returns (text: str, timed_out: bool).
    """
    q = queue.Queue()
    start = time.time()
    stop_event = threading.Event()
    warned_5s  = [False]
    def _read():
        try:
            val = sys.stdin.readline()   # raw read, no duplicate prompt echo
            q.put(val.rstrip('\n'))
        except EOFError:
            q.put("")
        finally:
            stop_event.set()

    def _tick():
        last_secs = -1
        while not stop_event.is_set():
            remaining = max(0.0, timeout - (time.time() - start))
            secs = int(remaining)

            if secs != last_secs:
                last_secs = secs

                # 5-second warning 
                if secs <= 5 and not warned_5s[0]:
                    warned_5s[0] = True
                    sys.stdout.write(f"\r  \033[91m⚠  5 SECONDS LEFT — choose now!\033[0m\n")
                    sys.stdout.flush()

                color   = "\033[91m" if secs <= 5 else ("\033[93m" if secs <= 10 else "\033[92m")
                reset   = "\033[0m"
                label   = f"\r{prompt_base} {color}[{secs}s]{reset}> "
                sys.stdout.write(label)
                sys.stdout.flush()

            if remaining <= 0:
                break
            time.sleep(0.1)
            
    sys.stdout.write(f"{prompt_base} \033[92m[{int(timeout)}s]\033[0m> ")
    sys.stdout.flush()

    reader = threading.Thread(target=_read, daemon=True)
    ticker = threading.Thread(target=_tick, daemon=True)
    reader.start()
    ticker.start()
    reader.join(timeout + 0.2)   
    stop_event.set()

    if reader.is_alive():
        sys.stdout.write("\n")
        sys.stdout.flush()
        return "", True

    return (q.get_nowait() if not q.empty() else ""), False

# Kept as a plain (no-countdown) fallback used internally
def timed_input(prompt, timeout):
    q = queue.Queue()
    def _read():
        try:   q.put(input(prompt))
        except EOFError: q.put("")
    t = threading.Thread(target=_read, daemon=True)
    t.start();  t.join(timeout)
    if t.is_alive():
        print();  return "", True
    return q.get_nowait(), False

# BATTLE SUPPORT

class Battle:
    def __init__(self, party, enemies, battle_type="Standard Encounter"):
        self.party = party
        self.enemies = enemies
        self.turn_count = 0
        self.in_battle = True
        self.last_observed_target = None
        self.battle_type = battle_type
        self.is_game_over = False 

        # User's Custom Global Energy System
        self.party_energy = 3
        self.max_party_energy = 15
        self.group_ability_ready = False

        # Follow-Up & Team Mechanics
        self.momentum = 1.0
        self.affinity_matrix = {}
        self.fatigue_tracker = {}
        self.anyone_downed_this_battle = False
        self.inventory = PARTY_INVENTORY
        self.current_responder = None

    def add_party_energy(self, amount=1):
        if self.party_energy >= self.max_party_energy:
            return
        self.party_energy = min(self.max_party_energy, self.party_energy + amount)
        if self.party_energy >= self.max_party_energy:
            self.group_ability_ready = True
            print(f"\n  ★ GROUP ABILITY READY! Energy bar is full! ★")

    def spend_party_energy(self, amount):
        if self.party_energy >= amount:
            self.party_energy -= amount
            return True
        return False

    def energy_bar_display(self):
        filled  = self.party_energy
        empty   = self.max_party_energy - filled
        # Color the bar Yellow when full, Green when building
        bar_color = Colors.YELLOW if self.party_energy >= self.max_party_energy else Colors.LIGHT_GREEN
        bar = f"{bar_color}{'█' * filled}{Colors.RESET}{Colors.DARK_GRAY}{'░' * empty}{Colors.RESET}"
        label = f"{Colors.YELLOW}FULL!{Colors.RESET}" if self.party_energy >= self.max_party_energy else f"{self.party_energy}/{self.max_party_energy}"
        return f"[{bar}] {label}"

    def start_battle(self):
        self.party_energy = 3
        self.omori_did_not_succumb = False 
        for c in self.party + self.enemies:
            c.battle_start_emotion_applied = False
            if c.equipment is not None:
                c.equipment.apply_on_battle_start(c)

        # Register energy gain callback: every hit on a party member gives +1 energy
        for member in self.party:
            member.on_hit_callback = lambda: self.add_party_energy(1)

    def start_turn_reset(self):
        self.momentum = 1.0
        self.fatigue_tracker = {char.name: 0 for char in self.party}
        for char in self.party:
            char.readiness = min(1.0, getattr(char, 'readiness', 1.0) + 0.5)
            char.threat = max(0, int(getattr(char, 'threat', 0) * 0.8))
            char.has_followed_up = False

    def get_alive_foes(self):
        return[f for f in self.enemies if f.is_alive and not getattr(f, "is_downed", False)]

    def get_alive_party(self):
        return[p for p in self.party if p.is_alive and not getattr(p, "is_downed", False)]

    def check_victory(self):
        if not self.get_alive_foes():
            time.sleep(1.5)
            clear_screen()
            self.distribute_rewards() 
            self.in_battle = False
            return True
            
        if not self.get_alive_party():

            omori = next((p for p in self.party if p.name == "Omori"), None)
            if omori and not getattr(self, "omori_did_not_succumb", False):
                self.omori_did_not_succumb = True
                
                omori.is_downed = False
                omori.is_alive = True
                omori.hp = int(omori.max_hp * 0.5)
                omori.mana = int(omori.max_mana * 0.5)
                
                time.sleep(1.5)
                clear_screen()
                self.print_battle_status()
                print("\n" + Colors.GRAY + "━"*60 + Colors.RESET)
                print(f"  {Colors.RED}{Colors.BOLD}Omori did not succumb.{Colors.RESET}")
                print(Colors.GRAY + "━"*60 + Colors.RESET)
                time.sleep(3.0)
                
                return False 
            
            time.sleep(1.5)
            clear_screen()
            print("\n==================================")
            print("  DEFEAT... The party has fallen.")
            print("==================================")
            self.in_battle = False
            self.is_game_over = True 
            return True
            
        return False

    def distribute_rewards(self):
        global PARTY_COINS, SESSION_EARNED_XP, SESSION_EARNED_COINS
        print("\n" + Colors.YELLOW + "━"*50 + Colors.RESET)
        print(f" {Colors.BOLD}                BATTLE CLEARED!{Colors.RESET}")
        print(Colors.YELLOW + "━"*50 + Colors.RESET)

        total_xp = 0
        total_coins = 0

        # Base value, enemy type, and difficulty
        diff_mult = {"Easy": 0.85, "Normal": 1.0, "Hard": 1.2, "Brutal": 1.4}.get(DIFFICULTY, 1.0)
        type_mults = {"weak": 0.9, "normal": 1.0, "strong": 1.2, "dangerous": 1.4, "boss": 1.4}

        for foe in self.enemies: # Calculate from the original spawn list
            base_xp = 8 + (4 * foe.level)
            base_coins = 6 + (3 * foe.level)
            t_mult = type_mults.get(foe.enemy_type, 1.0)

            total_xp += (base_xp * t_mult * diff_mult)
            total_coins += (base_coins * t_mult * diff_mult)

        # Time bonus
        time_mult = 1.0
        if self.turn_count <= 2:
            time_mult = 1.10
            print(f" {Colors.CYAN}>> Speed Bonus: S Rank! (+10%){Colors.RESET}")
        elif self.turn_count <= 4:
            time_mult = 1.05
            print(f" {Colors.CYAN}>> Speed Bonus: A Rank! (+5%){Colors.RESET}")
            
        total_xp *= time_mult
        total_coins *= time_mult

        # Clean victory bonus
        if not self.anyone_downed_this_battle:
            total_xp *= 1.10
            print(f" {Colors.CYAN}>> Clean Victory! No downs! (+10% XP){Colors.RESET}")

        group_mult = 1.0
        is_multi = any(getattr(f, 'is_multi_being', False) for f in self.enemies)
        num_foes = len(self.enemies)
        
        if is_multi:
            group_mult = 2.0
            print(f" {Colors.CYAN}>> Massive Threat Defeated! (x2.0 Rewards){Colors.RESET}")
        elif num_foes >= 4:
            group_mult = 1.7
            print(f" {Colors.CYAN}>> Swarm Bonus! (x1.7 Rewards){Colors.RESET}")
        elif num_foes == 3:
            group_mult = 1.4
            print(f" {Colors.CYAN}>> Group Bonus! (x1.4 Rewards){Colors.RESET}")

        total_xp *= group_mult
        total_coins *= group_mult

        final_xp = int(total_xp)
        final_coins = int(total_coins)

        PARTY_COINS += final_coins
        SESSION_EARNED_XP += final_xp
        SESSION_EARNED_COINS += final_coins
        
        print(f"\n {Colors.YELLOW}★ Total Coins Found: {final_coins} (Wallet: {PARTY_COINS}){Colors.RESET}")
        print(f" {Colors.GREEN}★ Total XP Earned: {final_xp}{Colors.RESET}\n")

        # Distribute XP
        for p in self.party:
            if p.is_alive and not getattr(p, "is_downed", False):
                p.gain_xp(final_xp)

        # Item drops
        for foe in self.enemies:
            if hasattr(foe, 'drop_table'):
                for item_name, chance in foe.drop_table:
                    if random.random() <= chance:
                        if item_name in EQUIPMENT:
                            PARTY_EQUIPMENT_OWNED.append(EQUIPMENT[item_name])
                            print(f" 🎁 {Colors.PINK}Equipment Drop: {item_name} (from {foe.name})!{Colors.RESET}")
                        else:
                            self.inventory[item_name] = self.inventory.get(item_name, 0) + 1
                            print(f" 🎁 {Colors.PINK}Loot Drop: {item_name} (from {foe.name})!{Colors.RESET}")

        print(Colors.YELLOW + "━"*50 + Colors.RESET)

    def get_all_combatants(self):
        everyone = self.party + self.enemies
        sorted_everyone = sorted(everyone, key=lambda x: (x.temp_values.get("act_first_next_turn", 0), x.get_effective_stat("spd")), reverse=True)

        # Omori ALWAYS goes first because he is the player
        omori = next((c for c in sorted_everyone if c.name == "Omori"), None)
        if omori:
            sorted_everyone.remove(omori)
            sorted_everyone.insert(0, omori)

        return sorted_everyone

    def get_allies(self, user):
        return self.party if user in self.party else self.enemies

    def get_foes(self, user):
        return self.enemies if user in self.party else self.party

    def choose_random_target(self, user, side="foes"):
        pool = self.get_foes(user) if side == "foes" else self.get_allies(user)
        living =[c for c in pool if c.is_alive and not getattr(c, "is_downed", False)]
        return random.choice(living) if living else None

    def choose_any_target(self, user):
        allies =[c for c in self.get_allies(user) if c.is_alive and not getattr(c, "is_downed", False)]
        foes =[c for c in self.get_foes(user) if c.is_alive and not getattr(c, "is_downed", False)]
        pool = allies + foes
        return random.choice(pool) if pool else None

    def resolve_targets(self, user, scope, target=None):
        allies =[c for c in self.get_allies(user) if c.is_alive and not getattr(c, "is_downed", False)]
        foes =[c for c in self.get_foes(user) if c.is_alive and not getattr(c, "is_downed", False)]

        if scope in ["single_ally", "single_target"]:
            if target and target in allies:
                return [target]
            return [random.choice(allies)] if allies else []

        if scope == "single_foe":
            if target and target in foes:
                return[target]
            return [random.choice(foes)] if foes else[]

        if scope == "all_allies":
            return allies

        if scope == "all_foes":
            return foes

        if scope == "single_any":
            if target and target.is_alive and not getattr(target, "is_downed", False):
                return [target]
            pool = allies + foes
            return [random.choice(pool)] if pool else []

        if scope == "single_any_ally":
            if target and target in self.party: return [target]
            return[random.choice(self.party)] if self.party else []

        return[]

    def tick_item_cooldowns(self):
        for c in self.party + self.enemies:
            if hasattr(c, "item_cooldowns"):
                for k in list(c.item_cooldowns.keys()):
                    c.item_cooldowns[k] -= 1
                    if c.item_cooldowns[k] <= 0:
                        del c.item_cooldowns[k]

    def use_skill(self, user, skill_name, target=None):
        if skill_name == "Attack":
            base_attack = Skill("Attack", 0, 1, "single_foe", "basic_attack")
            return base_attack.execute(user, self, target)
            
        if skill_name not in user.skills:
            return f"{user.name} has not unlocked {skill_name}."

        skill = user.skills[skill_name]
        return skill.execute(user, self, target)

    def on_target_defeated(self, user, target):
        self.add_party_energy(5)

    def enemy_ai_choose_target(self, enemy):
        valid_targets =[p for p in self.party if p.is_alive and not getattr(p, "is_downed", False)]
        if not valid_targets:
            return None
        return max(valid_targets, key=lambda t: getattr(t, 'threat', 0) * random.uniform(0.8, 1.2))

    def evaluate_follow_ups(self, initiator, event_type, target):
        valid_follow_ups =[]
        if getattr(initiator, "has_followed_up", False): return[]
        if not hasattr(initiator, "follow_up_skills"): return[]
        is_redline = getattr(self, "redline_discount", False)

        for fu_skill in initiator.follow_up_skills:
            current_cost = fu_skill.cost
            if is_redline:
                current_cost = 1
            
            if self.party_energy < current_cost:
                continue 
            if fu_skill.target_type == "Team":
                all_alive = all(p.is_alive and not getattr(p, "is_downed", False) for p in self.party)
                if all_alive:                
                    valid_follow_ups.append({"character": initiator, "responder": None, "skill": fu_skill, "cost" : current_cost})
                    continue
            responder = next((p for p in self.party if p.name == fu_skill.target_type), None)
            
            if responder and responder.is_alive and not getattr(responder, "is_downed", False) and not getattr(responder, "has_followed_up", False):
               valid_follow_ups.append({"character": initiator, "responder": responder, "skill": fu_skill, "cost" : current_cost})
               
        return valid_follow_ups

    def execute_follow_up(self, initiator, responder, target, follow_up_skill):
        self.spend_party_energy(follow_up_skill["cost"])
        responder.has_followed_up = True
        print(f"  → FOLLOW-UP: {responder.name} reacts to {initiator.name}! (-{follow_up_skill['cost']} Energy)")
        
    def print_turn_header(self, player, context="TURN"):
        """Central UI Engine: Guarantees the HUD and the Turn Banner NEVER vanish"""
        clear_screen()
        self.print_battle_status()
        omori_color = Colors.GRAY if "Omori" in player.name else ""
        print(f"\n{omori_color}==> {player.name.upper()}'S {context} <=={Colors.RESET}")

    def prompt_target(self, user, side="foes", deadline=None):
        if side == "any":
            targets = self.get_alive_party() + self.get_alive_foes()
        elif side == "allies_all_states": targets = self.party
        else: targets = self.get_alive_foes() if side == "foes" else self.get_alive_party()

        if not targets:
            return None

        self.print_turn_header(user, "TARGETING")
        print("\nChoose a target:")
        print(f"[{Colors.RED}0{Colors.RESET}] Cancel")
        
        for i, t in enumerate(targets):
            if not t.is_alive or getattr(t, "is_downed", False):
                print(f"[{Colors.CYAN}{i+1}{Colors.RESET}] {Colors.DARK_GRAY}{t.name} [DOWNED]{Colors.RESET}")
            else:
                hp_display = t.get_display_hp() if hasattr(t, 'get_display_hp') else f"{t.hp}/{t.max_hp}"
                name_str = f"{Colors.LIGHT_GRAY}{t.name}{Colors.RESET}" if "Omori" in t.name else t.name
                if getattr(t, "is_obscured", lambda: False)():
                    hp_display = "???"
                    emo_color = Colors.PURPLE
                    emo_raw = "???"
                else:
                    hp_display = t.get_display_hp() if hasattr(t, 'get_display_hp') else f"{t.hp}/{t.max_hp}"
                emo_raw = t.emotion.capitalize()
                emo_color = EMOTION_COLORS.get(t.emotion.lower(), Colors.RESET)
                print(f"[{Colors.CYAN}{i+1}{Colors.RESET}] {name_str} (HP: {hp_display} | Emotion: {emo_color}{emo_raw}{Colors.RESET})")

        while True:
            if deadline is not None and time.time() >= deadline: return None

            if deadline is not None:
                left = max(0.1, deadline - time.time())
                raw, timed_out = timed_input_countdown("Target", left)
                if timed_out: return None
            else:
                raw = input("Target #> ")

            raw = raw.strip()
            if raw == "0": return None # Allow canceling out of Target menu

            try:
                choice = int(raw) - 1
                if 0 <= choice < len(targets):
                    return targets[choice]
            except ValueError:
                pass

            if deadline is not None and time.time() >= deadline: return None
            print("Invalid choice.")

