    @staticmethod
    def _dmg_str(target, dealt):
        """Returns ??? if the target is obscured, otherwise returns the HP and MP damage breakdown."""
        if getattr(target, 'is_obscured', lambda: False)():
            return "???"
            
        # Fetch the exact breakdown stored by receive_formula_damage
        hp_dmg = getattr(target, 'last_hp_dmg', int(dealt))
        mp_dmg = getattr(target, 'last_mp_dmg', 0)
        
        # Format dynamically
        if mp_dmg > 0 and hp_dmg > 0:
            return f"{hp_dmg} HP and {mp_dmg} MP"
        elif mp_dmg > 0 and hp_dmg <= 0:
            return f"{mp_dmg} MP"
        else:
            return f"{hp_dmg} HP"

    @staticmethod
    def execute_skill(skill, user, battle, target=None):
        is_redline_atk = user.temp_values.get("redline_active") and skill.kind in["basic_attack", "damage", "damage_ignore_def", "multi_hit", "random_multi_hit", "aoe_damage"]
        
        if target is None or (hasattr(target, "is_alive") and not target.is_alive):
            if is_redline_atk or skill.kind.startswith("fu_"):
                target = battle.choose_random_target(user, side="foes")
                
        if is_redline_atk and battle: battle.redline_discount = True

        result = SkillLibrary._execute_skill_internal(skill, user, battle, target)
        
        if is_redline_atk and battle and getattr(battle, "in_battle", False) and user in getattr(battle, 'party',[]):
            
            fu_target = target
            if fu_target is None or not fu_target.is_alive:
                fu_target = battle.choose_random_target(user, side="foes")
                
            follow_ups = battle.evaluate_follow_ups(user, "redline", fu_target)
            if follow_ups:
                for fu in follow_ups:
                    fu["cost"] = 1
                if result:
                    animated_print(f"\n{result}")
                    result = "" 
                time.sleep(1.5)
                battle.interactive_follow_up(user, follow_ups, fu_target)

        if is_redline_atk:
            if result is not None: result += SkillLibrary._cleanup_redline(user, battle=battle)
            else: result = SkillLibrary._cleanup_redline(user, battle=battle)
            if battle: battle.redline_discount = False
        
        if battle:
            for c in battle.party + battle.enemies:
                if getattr(c, 'battle_announcements',[]):
                    for msg in c.battle_announcements:
                        if result is not None: result += msg
                    c.battle_announcements.clear()
                    
        return result

    @staticmethod
    def _execute_skill_internal(skill, user, battle, target=None):
        allies = battle.get_allies(user)
        foes = battle.get_foes(user)
        sd = skill.data
        
        if skill.kind == "basic_attack":
            if target is None: 
                target = battle.choose_random_target(user, side="foes")
                
            raw = SkillLibrary._base_damage(user, target, 1.0) 
            dealt, missed = SkillLibrary._finalize_damage(user, target, raw, battle=battle, is_basic_attack=True)
            
            action_txt = Narrator.attack(user.name, target.name)
            
            if missed: 
                result_str = f"{action_txt}\n<DELAY:0.8>  ...but missed entirely!"
            else: 
                result_str = f"{action_txt}\n<DELAY:0.8>  ...dealing {SkillLibrary._dmg_str(target, dealt)} damage!"
            
            result_str = SkillLibrary._append_hit_fx(result_str, battle)

            if battle and getattr(battle, "in_battle", False) and user in getattr(battle, 'party',[]):
                is_rl = getattr(battle, "redline_discount", False)
               
                if not is_rl: 
                    follow_ups = battle.evaluate_follow_ups(user, "basic_attack", target)
                    if follow_ups:
                        animated_print(f"\n{result_str}")
                        time.sleep(1.5)
                        battle.interactive_follow_up(user, follow_ups, target)
                        return ""
                        
            return result_str

        if skill.kind == "redline_stance":
            if user.temp_values.get("redline_active"): return f"{user.name} is already in Redline!"
            
            hp_loss = int(user.max_hp * 0.10)
            user.hp = max(1, user.hp - hp_loss)
            
            SkillLibrary._apply_status(user, "Speed++", 99, battle=battle)
            SkillLibrary._apply_status(user, "Attack+", 99, battle=battle)
            user.apply_temp_effect("redline_active", 1, 99)
            user.apply_temp_effect("redline_immunity", 1, 99)
            
