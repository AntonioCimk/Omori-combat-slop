def get_skill_desc(skill):
    k = skill.kind
    d = skill.data
    desc = ""
    
    # Base Mechanics
    if k == "basic_attack": desc = "A standard physical attack."
    elif k == "damage": 
        stat_name = d.get("stat", "atk").upper()
        desc = f"Deals {d.get('mult',1.0)}x {stat_name} damage."
        if d.get("always_crit"): desc = f"Guaranteed Critical Hit! Deals {d.get('mult',1.0)}x {stat_name} damage."
    elif k == "damage_ignore_def": 
        stat_name = d.get("stat", "atk").upper()
        desc = f"Deals {d.get('mult',1.0)}x {stat_name} damage (Ignores DEF)."
    elif k == "multi_hit": 
        stat_name = d.get("stat", "atk").upper()
        desc = f"Hits {d.get('hits',2)} times for {d.get('mult',1.0)}x {stat_name}."
