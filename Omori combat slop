# ITEM / EQUIPMENT DEFINITIONS

class Foe(Character):
    def __init__(self, name, base_hp, base_mp, base_atk, base_dfn, base_spd, level, 
                 max_emo_level=1, enemy_type="normal", is_multi_being=False, drop_table=None):
        
        # Standard Foe Scaling
        hp = (base_hp * 3) + int(120 * (level - 1))
        mp = (base_mp * 2) + int(15 * (level - 1))
        atk = int(base_atk * 2.0) + int(6.0 * (level - 1))
        dfn = int(base_dfn * 2.0) + int(4.0 * (level - 1))
        spd = int(base_spd * 1.5) + int(1.5 * (level - 1))
        
        diff_mult = {"Easy": 0.85, "Normal": 1.0, "Hard": 1.2, "Brutal": 1.4}.get(DIFFICULTY, 1.0)
        hp = int(hp * diff_mult)
        mp = int(mp * diff_mult)
        atk = int(atk * diff_mult)
        
        super().__init__(name, hp, mp, atk, dfn, spd)
        
        self.level = level
        self.max_emotion_level = max_emo_level
        self.enemy_type = enemy_type
        self.is_multi_being = is_multi_being
        self.drop_table = drop_table or[]

    def take_turn(self, battle):
        pass

# ADVANCED BOSSES
class GildedSun(Foe):
    def __init__(self, level):
        super().__init__("The Gilded Sun", 260, 90, 18, 16, 14, level, max_emo_level=3, enemy_type="boss")
        diff_mult = {"Easy": 0.85, "Normal": 1.0, "Hard": 1.2, "Brutal": 1.4}.get(DIFFICULTY, 1.0)
       
        self.max_hp = self.hp = int(10000 * diff_mult)
        self.max_mana = self.mana = int(5000 * diff_mult)
        self.base_atk = int(80 * diff_mult)
        self.base_dfn = int(50 * diff_mult)
        self.base_spd = int(105 * diff_mult)
        self.drop_table =[("Hero’s Emblem", 1.0), ("Sanctuary Drink", 0.5)]
        self.emotion_lock_tier = 0

    def set_emotion(self, emotion, duration=0):
        target_root = Emotions.get_root(emotion)
        if getattr(self, 'emotion_lock_tier', 0) > 0 and target_root != "happy":
            locked_emo = "manic" if self.emotion_lock_tier == 3 else ("ecstatic" if self.emotion_lock_tier == 2 else "happy")
            self.battle_announcements.append(f"<DELAY:0.5>\n  [!] {self.name} is permanently locked! It cannot be changed from {format_emo(locked_emo)}!")
            return
        super().set_emotion(emotion, duration)

    def receive_formula_damage(self, amount):
        dmg = super().receive_formula_damage(amount)
        pct = self.hp / max(1, self.max_hp)
        if pct <= 0.40 and self.emotion_lock_tier < 3:
            self.emotion_lock_tier = 3
            self.emotion = "manic"; self.emotion_duration = 999
            self.battle_announcements.append(f"<DELAY:0.8>\n  [!] The Gilded Sun reaches its peak! It is permanently locked to {format_emo('manic')}!")
        elif pct <= 0.60 and self.emotion_lock_tier < 2:
            self.emotion_lock_tier = 2
            self.emotion = "ecstatic"; self.emotion_duration = 999
            self.battle_announcements.append(f"<DELAY:0.8>\n  [!] The Gilded Sun is glowing! It is permanently locked to {format_emo('ecstatic')}!")
        elif pct <= 0.80 and self.emotion_lock_tier < 1:
            self.emotion_lock_tier = 1
            self.emotion = "happy"; self.emotion_duration = 999
            self.battle_announcements.append(f"<DELAY:0.8>\n  [!] The Gilded Sun shines! It is permanently locked to {format_emo('happy')}!")
        return dmg

    def take_turn(self, battle):
        foes =[f for f in battle.get_foes(self) if f.is_alive and not getattr(f, "is_downed", False)]
        target = battle.choose_random_target(self, side="foes")
        move = random.choice(["Radiant Decree", "Blazing Smile", "Golden Collapse", "Merciful Glow"])
        animated_print(f"{Narrator.enemy_action(self.name, move, target.name if move == 'Blazing Smile' and target else None)}")

        if move == "Radiant Decree" and foes:
            if getattr(self, 'emotion_lock_tier', 0) == 0: self.set_emotion("happy", 999)
            self.try_add_status("Speed+", 2)
            raw = self.get_effective_stat("atk") * 1.5
            for f in foes:
                f.set_emotion("angry", 2); f.try_add_status("Defense-", 2)
                dealt, missed = SkillLibrary._finalize_damage(self, f, raw, battle=battle)
                if not missed: animated_print(SkillLibrary._append_hit_fx(f"<DELAY:0.4>  Scorched {f.name} for {SkillLibrary._dmg_str(f, dealt)} damage!", battle))
                else: animated_print(f"<DELAY:0.4>  {f.name} dodged the Radiant Decree!")
            animated_print(f"<DELAY:0.8>  The blinding light forces everyone into a Rage and lowers Defense!")
            
        elif move == "Blazing Smile" and target:
            raw = self.get_effective_stat("atk") * 1.5 + (target.get_effective_stat("spd") * 0.5)
            if Emotions.get_root(target.emotion) == "angry": raw *= 1.5
            dealt, missed = SkillLibrary._finalize_damage(self, target, raw, battle=battle)
            if missed: animated_print(f"<DELAY:0.8>  ...but {target.name} dodged!")
            else: animated_print(SkillLibrary._append_hit_fx(f"<DELAY:0.8>  ...dealing {SkillLibrary._dmg_str(target, dealt)} heavy damage!", battle))
            
